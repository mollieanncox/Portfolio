---
import Base from '../../layouts/Base.astro';
---

<Base
  title="PX Org Strategy · Mollie Cox"
  description="Evolving a product design function into a strategic Product Experience organization spanning design, content, documentation, research, education, community, and AI."
>
  <!-- ============================== -->
  <!-- HERO -->
  <!-- ============================== -->
  <section class="case-hero-dark">
    <div class="max-w-7xl mx-auto px-6 md:px-10 py-20 md:py-28 relative z-10">
      <a
        href="/#work"
        class="inline-flex items-center gap-2 font-mono text-xs uppercase tracking-[0.15em] text-cream/60 hover:text-orange transition-colors mb-16"
      >
        ← All work
      </a>

      <div class="grid grid-cols-1 md:grid-cols-12 gap-8 md:gap-12 items-start">

        <!-- Text column -->
        <div class="md:col-span-7">
          <p class="eyebrow-light mb-6">Branch · 2025 to 2026</p>

          <h1 class="font-display text-display-lg text-cream leading-[0.95] tracking-tight">
            From design function to product experience organization<span class="brand-period">.</span>
          </h1>

          <p class="mt-10 text-xl text-cream/80 leading-relaxed max-w-[48ch]">
            Evolving a design-centered team into a multi-disciplinary product organization
            spanning design, content, documentation, research, product education, customer
            community, and AI-enabled experience quality. Six pillars. One North Star. A
            measurable maturity model.
          </p>
        </div>

        <!-- Artifact column -->
        <div class="md:col-span-5 flex justify-center md:justify-end items-start mt-8 md:mt-0">
          <div class="case-hero-artifact w-full max-w-sm md:max-w-none">
            <svg viewBox="0 0 480 560" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Six pillars of Product Experience stacked as architectural strata with the North Star running through as an orange thread">

              <!-- Subtle grid backdrop -->
              <g opacity="0.06">
                <line stroke="#F4EFE5" stroke-width="0.5" x1="80" y1="40" x2="80" y2="520"/>
                <line stroke="#F4EFE5" stroke-width="0.5" x1="160" y1="40" x2="160" y2="520"/>
                <line stroke="#F4EFE5" stroke-width="0.5" x1="240" y1="40" x2="240" y2="520"/>
                <line stroke="#F4EFE5" stroke-width="0.5" x1="320" y1="40" x2="320" y2="520"/>
                <line stroke="#F4EFE5" stroke-width="0.5" x1="400" y1="40" x2="400" y2="520"/>
              </g>

              <!-- North Star vertical thread -->
              <line x1="280" y1="50" x2="280" y2="510" stroke="#E13D0F" stroke-width="2" stroke-linecap="round"/>

              <!-- North Star marker at top -->
              <circle cx="280" cy="40" r="8" fill="#02101D" stroke="#E13D0F" stroke-width="2"/>
              <circle cx="280" cy="40" r="3" fill="#E13D0F"/>
              <text x="280" y="22" text-anchor="middle" fill="#E13D0F" font-family="'JetBrains Mono', ui-monospace, monospace" font-size="9" letter-spacing="2">NORTH STAR</text>

              <!-- Pillar 01: Design -->
              <g transform="translate(0, 80)">
                <rect x="60" y="0" width="360" height="50" rx="2" fill="none" stroke="#F4EFE5" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                <g transform="translate(90, 25)">
                  <rect x="-10" y="-9" width="9" height="7" fill="none" stroke="#F4EFE5" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" rx="0.5"/>
                  <rect x="1" y="-9" width="9" height="7" fill="none" stroke="#F4EFE5" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" rx="0.5"/>
                  <rect x="-10" y="0" width="20" height="7" fill="none" stroke="#F4EFE5" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" rx="0.5"/>
                </g>
                <text x="130" y="22" fill="#E13D0F" font-family="'JetBrains Mono', ui-monospace, monospace" font-size="11" font-weight="500" letter-spacing="2">01</text>
                <text x="130" y="38" fill="#F4EFE5" font-family="'JetBrains Mono', ui-monospace, monospace" font-size="10" letter-spacing="2" opacity="0.92">DESIGN</text>
                <line x1="340" y1="14" x2="410" y2="14" stroke="#F4EFE5" stroke-width="1" opacity="0.3"/>
                <line x1="340" y1="25" x2="410" y2="25" stroke="#F4EFE5" stroke-width="1" opacity="0.3"/>
                <line x1="340" y1="36" x2="410" y2="36" stroke="#F4EFE5" stroke-width="1" opacity="0.3"/>
                <circle cx="280" cy="25" r="4" fill="#E13D0F"/>
              </g>

              <!-- Pillar 02: Content -->
              <g transform="translate(0, 150)">
                <rect x="60" y="0" width="360" height="50" rx="2" fill="none" stroke="#F4EFE5" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                <g transform="translate(90, 25)">
                  <path d="M-9,-10 L-9,10 L9,10 L9,-5 L4,-10 Z" fill="none" stroke="#F4EFE5" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                  <line x1="-5" y1="-3" x2="5" y2="-3" stroke="#F4EFE5" stroke-width="1" stroke-linecap="round"/>
                  <line x1="-5" y1="2" x2="5" y2="2" stroke="#F4EFE5" stroke-width="1" stroke-linecap="round"/>
                  <line x1="-5" y1="7" x2="2" y2="7" stroke="#F4EFE5" stroke-width="1" stroke-linecap="round"/>
                </g>
                <text x="130" y="22" fill="#E13D0F" font-family="'JetBrains Mono', ui-monospace, monospace" font-size="11" font-weight="500" letter-spacing="2">02</text>
                <text x="130" y="38" fill="#F4EFE5" font-family="'JetBrains Mono', ui-monospace, monospace" font-size="10" letter-spacing="2" opacity="0.92">CONTENT</text>
                <line x1="340" y1="14" x2="410" y2="14" stroke="#F4EFE5" stroke-width="1" opacity="0.3"/>
                <line x1="340" y1="25" x2="410" y2="25" stroke="#F4EFE5" stroke-width="1" opacity="0.3"/>
                <line x1="340" y1="36" x2="410" y2="36" stroke="#F4EFE5" stroke-width="1" opacity="0.3"/>
                <circle cx="280" cy="25" r="4" fill="#E13D0F"/>
              </g>

              <!-- Pillar 03: Documentation -->
              <g transform="translate(0, 220)">
                <rect x="60" y="0" width="360" height="50" rx="2" fill="none" stroke="#F4EFE5" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                <g transform="translate(90, 25)">
                  <path d="M-10,-8 L-10,8 L0,9 L10,8 L10,-8 L0,-7 Z" fill="none" stroke="#F4EFE5" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                  <line x1="0" y1="-7" x2="0" y2="9" stroke="#F4EFE5" stroke-width="2" stroke-linecap="round"/>
                  <line x1="-7" y1="-2" x2="-3" y2="-1" stroke="#F4EFE5" stroke-width="1" stroke-linecap="round"/>
                  <line x1="3" y1="-1" x2="7" y2="-2" stroke="#F4EFE5" stroke-width="1" stroke-linecap="round"/>
                  <line x1="-7" y1="3" x2="-3" y2="4" stroke="#F4EFE5" stroke-width="1" stroke-linecap="round"/>
                </g>
                <text x="130" y="22" fill="#E13D0F" font-family="'JetBrains Mono', ui-monospace, monospace" font-size="11" font-weight="500" letter-spacing="2">03</text>
                <text x="130" y="38" fill="#F4EFE5" font-family="'JetBrains Mono', ui-monospace, monospace" font-size="10" letter-spacing="2" opacity="0.92">DOCS</text>
                <line x1="340" y1="14" x2="410" y2="14" stroke="#F4EFE5" stroke-width="1" opacity="0.3"/>
                <line x1="340" y1="25" x2="410" y2="25" stroke="#F4EFE5" stroke-width="1" opacity="0.3"/>
                <line x1="340" y1="36" x2="410" y2="36" stroke="#F4EFE5" stroke-width="1" opacity="0.3"/>
                <circle cx="280" cy="25" r="4" fill="#E13D0F"/>
              </g>

              <!-- Pillar 04: Research -->
              <g transform="translate(0, 290)">
                <rect x="60" y="0" width="360" height="50" rx="2" fill="none" stroke="#F4EFE5" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                <g transform="translate(90, 25)">
                  <circle cx="-2" cy="-2" r="8" fill="none" stroke="#F4EFE5" stroke-width="2" stroke-linecap="round"/>
                  <line x1="4" y1="4" x2="10" y2="10" stroke="#F4EFE5" stroke-width="2" stroke-linecap="round"/>
                  <line x1="-5" y1="-1" x2="-5" y2="1" stroke="#F4EFE5" stroke-width="1" stroke-linecap="round"/>
                  <line x1="-2" y1="-3" x2="-2" y2="1" stroke="#F4EFE5" stroke-width="1" stroke-linecap="round"/>
                  <line x1="1" y1="-5" x2="1" y2="1" stroke="#F4EFE5" stroke-width="1" stroke-linecap="round"/>
                </g>
                <text x="130" y="22" fill="#E13D0F" font-family="'JetBrains Mono', ui-monospace, monospace" font-size="11" font-weight="500" letter-spacing="2">04</text>
                <text x="130" y="38" fill="#F4EFE5" font-family="'JetBrains Mono', ui-monospace, monospace" font-size="10" letter-spacing="2" opacity="0.92">RESEARCH</text>
                <line x1="340" y1="14" x2="410" y2="14" stroke="#F4EFE5" stroke-width="1" opacity="0.3"/>
                <line x1="340" y1="25" x2="410" y2="25" stroke="#F4EFE5" stroke-width="1" opacity="0.3"/>
                <line x1="340" y1="36" x2="410" y2="36" stroke="#F4EFE5" stroke-width="1" opacity="0.3"/>
                <circle cx="280" cy="25" r="4" fill="#E13D0F"/>
              </g>

              <!-- Pillar 05: Community -->
              <g transform="translate(0, 360)">
                <rect x="60" y="0" width="360" height="50" rx="2" fill="none" stroke="#F4EFE5" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                <g transform="translate(90, 25)">
                  <circle cx="-6" cy="-4" r="4" fill="none" stroke="#F4EFE5" stroke-width="2" stroke-linecap="round"/>
                  <circle cx="6" cy="-4" r="4" fill="none" stroke="#F4EFE5" stroke-width="2" stroke-linecap="round"/>
                  <circle cx="0" cy="6" r="4" fill="none" stroke="#F4EFE5" stroke-width="2" stroke-linecap="round"/>
                  <line x1="-3" y1="-2" x2="3" y2="-2" stroke="#F4EFE5" stroke-width="1" stroke-linecap="round"/>
                  <line x1="-4" y1="-1" x2="-1" y2="4" stroke="#F4EFE5" stroke-width="1" stroke-linecap="round"/>
                  <line x1="4" y1="-1" x2="1" y2="4" stroke="#F4EFE5" stroke-width="1" stroke-linecap="round"/>
                </g>
                <text x="130" y="22" fill="#E13D0F" font-family="'JetBrains Mono', ui-monospace, monospace" font-size="11" font-weight="500" letter-spacing="2">05</text>
                <text x="130" y="38" fill="#F4EFE5" font-family="'JetBrains Mono', ui-monospace, monospace" font-size="10" letter-spacing="2" opacity="0.92">COMMUNITY</text>
                <line x1="340" y1="14" x2="410" y2="14" stroke="#F4EFE5" stroke-width="1" opacity="0.3"/>
                <line x1="340" y1="25" x2="410" y2="25" stroke="#F4EFE5" stroke-width="1" opacity="0.3"/>
                <line x1="340" y1="36" x2="410" y2="36" stroke="#F4EFE5" stroke-width="1" opacity="0.3"/>
                <circle cx="280" cy="25" r="4" fill="#E13D0F"/>
              </g>

              <!-- Pillar 06: AI -->
              <g transform="translate(0, 430)">
                <rect x="60" y="0" width="360" height="50" rx="2" fill="none" stroke="#F4EFE5" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                <g transform="translate(90, 25)">
                  <rect x="-8" y="-8" width="16" height="16" fill="none" stroke="#F4EFE5" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" rx="0.5"/>
                  <rect x="-4" y="-4" width="8" height="8" fill="none" stroke="#F4EFE5" stroke-width="1"/>
                  <line x1="-11" y1="-4" x2="-8" y2="-4" stroke="#F4EFE5" stroke-width="1" stroke-linecap="round"/>
                  <line x1="-11" y1="0" x2="-8" y2="0" stroke="#F4EFE5" stroke-width="1" stroke-linecap="round"/>
                  <line x1="-11" y1="4" x2="-8" y2="4" stroke="#F4EFE5" stroke-width="1" stroke-linecap="round"/>
                  <line x1="8" y1="-4" x2="11" y2="-4" stroke="#F4EFE5" stroke-width="1" stroke-linecap="round"/>
                  <line x1="8" y1="0" x2="11" y2="0" stroke="#F4EFE5" stroke-width="1" stroke-linecap="round"/>
                  <line x1="8" y1="4" x2="11" y2="4" stroke="#F4EFE5" stroke-width="1" stroke-linecap="round"/>
                  <line x1="-4" y1="-11" x2="-4" y2="-8" stroke="#F4EFE5" stroke-width="1" stroke-linecap="round"/>
                  <line x1="0" y1="-11" x2="0" y2="-8" stroke="#F4EFE5" stroke-width="1" stroke-linecap="round"/>
                  <line x1="4" y1="-11" x2="4" y2="-8" stroke="#F4EFE5" stroke-width="1" stroke-linecap="round"/>
                  <line x1="-4" y1="8" x2="-4" y2="11" stroke="#F4EFE5" stroke-width="1" stroke-linecap="round"/>
                  <line x1="0" y1="8" x2="0" y2="11" stroke="#F4EFE5" stroke-width="1" stroke-linecap="round"/>
                  <line x1="4" y1="8" x2="4" y2="11" stroke="#F4EFE5" stroke-width="1" stroke-linecap="round"/>
                </g>
                <text x="130" y="22" fill="#E13D0F" font-family="'JetBrains Mono', ui-monospace, monospace" font-size="11" font-weight="500" letter-spacing="2">06</text>
                <text x="130" y="38" fill="#F4EFE5" font-family="'JetBrains Mono', ui-monospace, monospace" font-size="10" letter-spacing="2" opacity="0.92">AI</text>
                <line x1="340" y1="14" x2="410" y2="14" stroke="#F4EFE5" stroke-width="1" opacity="0.3"/>
                <line x1="340" y1="25" x2="410" y2="25" stroke="#F4EFE5" stroke-width="1" opacity="0.3"/>
                <line x1="340" y1="36" x2="410" y2="36" stroke="#F4EFE5" stroke-width="1" opacity="0.3"/>
                <circle cx="280" cy="25" r="4" fill="#E13D0F"/>
              </g>

              <!-- Base label -->
              <text x="280" y="540" text-anchor="middle" fill="#E13D0F" font-family="'JetBrains Mono', ui-monospace, monospace" font-size="9" letter-spacing="2" opacity="0.6">ONE NORTH STAR</text>
            </svg>
          </div>
        </div>

      </div>

      <div class="mt-20 grid grid-cols-2 md:grid-cols-4 gap-6 pt-10 border-t border-cream/15 relative z-10">
        <div>
          <p class="eyebrow-light mb-2">Role</p>
          <p class="text-cream">Sr. Director, Product Experience</p>
        </div>
        <div>
          <p class="eyebrow-light mb-2">Duration</p>
          <p class="text-cream">Multi-quarter</p>
        </div>
        <div>
          <p class="eyebrow-light mb-2">Team</p>
          <p class="text-cream">~15-person org scope</p>
        </div>
        <div>
          <p class="eyebrow-light mb-2">Outcome</p>
          <p class="text-cream">Operating model adopted</p>
        </div>
      </div>
    </div>
  </section>

  <!-- =============================== -->
  <!-- North Star -->
  <!-- =============================== -->
  <section class="grid-backdrop border-b border-ink/10 overflow-hidden">
    <div class="grid-backdrop-band-top"></div>
    <div class="grid-backdrop-band-bottom"></div>
    <div class="max-w-7xl mx-auto px-6 md:px-10 py-24 md:py-32 relative z-10">
      <p class="eyebrow-voice mb-8">The North Star</p>
      <h2 class="font-display text-ink leading-[1.0] tracking-tight max-w-[24ch]" style="font-size: clamp(2.5rem, 5.5vw, 5rem);">
        Make the product easier to understand, easier to adopt, <span class="text-orange italic">and harder to leave.</span>
      </h2>
      <p class="mt-12 text-xl text-ink-soft leading-relaxed max-w-3xl">
        Customer-centric. Business-relevant. Not design-centric. This framing was the
        unlock. It connects directly to usability, adoption, retention, customer
        confidence, product clarity, education, trust, and experience quality.
      </p>
    </div>
  </section>

  <!-- =============================== -->
  <!-- The problem -->
  <!-- =============================== -->
  <section class="max-w-7xl mx-auto px-6 md:px-10 py-24 md:py-32">
    <div class="grid md:grid-cols-12 gap-8 md:gap-16">
      <div class="md:col-span-4">
        <p class="eyebrow mb-3">The problem</p>
        <h2 class="font-display text-display-md text-ink leading-tight">
          Growing scope, no shared operating model.
        </h2>
      </div>
      <div class="md:col-span-8 max-w-reading">
        <p class="text-lg text-ink-soft leading-relaxed mb-6">
          The Product Experience function already extended beyond traditional product
          design. The team owned product design, UX research, product content,
          technical documentation, design systems, customer programs, in-product
          education, product quality, and emerging AI experience patterns.
        </p>
        <p class="text-lg text-ink-soft leading-relaxed mb-6">
          But without a clear strategy, that breadth looked like a collection of
          responsibilities rather than a coherent function. The company was entering a
          major product transformation across modernization, AI, analytics, and
          customer migration. Design could no longer operate as a downstream service
          function making screens after decisions were already made.
        </p>
        <p class="text-lg text-ink-soft leading-relaxed">
          PX needed to become a strategic product partner with a defined scope, a
          shared operating model, and measurable outcomes.
        </p>
      </div>
    </div>
  </section>

  <!-- =============================== -->
  <!-- THE SIX PILLARS - visual grid -->
  <!-- =============================== -->
  <section class="bg-cream-warm/40 border-y border-ink/10 py-24 md:py-32">
    <div class="max-w-7xl mx-auto px-6 md:px-10">
      <p class="eyebrow mb-3">The framework</p>
      <h2 class="font-display text-display-md text-ink leading-tight max-w-[24ch] mb-16">
        Six pillars under one North Star.
      </h2>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-4 md:gap-6">

        <!-- 01 Experience Quality -->
        <div class="lesson-card">
          <div class="linocut-icon">
            <svg viewBox="0 0 80 80" xmlns="http://www.w3.org/2000/svg">
              <circle cx="40" cy="40" r="28" fill="#E13D0F" stroke="#02101D" stroke-width="3"/>
              <path d="M28 40 L 36 48 L 54 30" fill="none" stroke="#F4EFE5" stroke-width="5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
          <p class="font-mono text-xs text-orange uppercase tracking-wider mb-2">Pillar 01</p>
          <h3 class="font-display text-2xl text-ink mb-4 leading-tight">Experience Quality.</h3>
          <p class="text-ink-soft leading-relaxed">
            UX quality, interaction patterns, design review, usability, accessibility,
            visual consistency, cross-product coherence. How PX protects the customer
            from organizational fragmentation.
          </p>
        </div>

        <!-- 02 Platform & Delivery -->
        <div class="lesson-card">
          <div class="linocut-icon">
            <svg viewBox="0 0 80 80" xmlns="http://www.w3.org/2000/svg">
              <rect x="14" y="14" width="20" height="20" fill="#E13D0F" stroke="#02101D" stroke-width="2.5"/>
              <rect x="46" y="14" width="20" height="20" fill="#E13D0F" stroke="#02101D" stroke-width="2.5"/>
              <rect x="14" y="46" width="20" height="20" fill="#02101D"/>
              <rect x="46" y="46" width="20" height="20" fill="#E13D0F" stroke="#02101D" stroke-width="2.5"/>
              <line x1="34" y1="24" x2="46" y2="24" stroke="#02101D" stroke-width="2"/>
              <line x1="24" y1="34" x2="24" y2="46" stroke="#02101D" stroke-width="2"/>
              <line x1="56" y1="34" x2="56" y2="46" stroke="#02101D" stroke-width="2"/>
            </svg>
          </div>
          <p class="font-mono text-xs text-orange uppercase tracking-wider mb-2">Pillar 02</p>
          <h3 class="font-display text-2xl text-ink mb-4 leading-tight">Experience Platform & Delivery.</h3>
          <p class="text-ink-soft leading-relaxed">
            Design system, component governance, design-engineering partnership, UI
            infrastructure, delivery standards. Where PX moves from craft to
            infrastructure.
          </p>
        </div>

        <!-- 03 Content & Clarity -->
        <div class="lesson-card">
          <div class="linocut-icon">
            <svg viewBox="0 0 80 80" xmlns="http://www.w3.org/2000/svg">
              <rect x="12" y="14" width="56" height="52" fill="#E13D0F" stroke="#02101D" stroke-width="3"/>
              <line x1="20" y1="26" x2="60" y2="26" stroke="#F4EFE5" stroke-width="2.5"/>
              <line x1="20" y1="34" x2="60" y2="34" stroke="#F4EFE5" stroke-width="2.5"/>
              <line x1="20" y1="42" x2="52" y2="42" stroke="#F4EFE5" stroke-width="2.5"/>
              <line x1="20" y1="50" x2="56" y2="50" stroke="#F4EFE5" stroke-width="2.5"/>
              <line x1="20" y1="58" x2="44" y2="58" stroke="#F4EFE5" stroke-width="2.5"/>
            </svg>
          </div>
          <p class="font-mono text-xs uppercase tracking-wider mb-2" style="color: #9B40C4;">Pillar 03</p>
          <h3 class="font-display text-2xl text-ink mb-4 leading-tight">Content & Clarity.</h3>
          <p class="text-ink-soft leading-relaxed">
            Product content, UX writing, technical documentation, help content, in-product
            language. Customers cannot adopt what they cannot understand.
          </p>
        </div>

        <!-- 04 Research & Insights -->
        <div class="lesson-card">
          <div class="linocut-icon">
            <svg viewBox="0 0 80 80" xmlns="http://www.w3.org/2000/svg">
              <circle cx="32" cy="32" r="18" fill="#E13D0F" stroke="#02101D" stroke-width="3"/>
              <line x1="22" y1="24" x2="42" y2="24" stroke="#F4EFE5" stroke-width="2"/>
              <line x1="22" y1="32" x2="42" y2="32" stroke="#F4EFE5" stroke-width="2"/>
              <line x1="22" y1="40" x2="38" y2="40" stroke="#F4EFE5" stroke-width="2"/>
              <line x1="48" y1="48" x2="68" y2="68" stroke="#02101D" stroke-width="5" stroke-linecap="round"/>
            </svg>
          </div>
          <p class="font-mono text-xs text-orange uppercase tracking-wider mb-2">Pillar 04</p>
          <h3 class="font-display text-2xl text-ink mb-4 leading-tight">Research & Insights.</h3>
          <p class="text-ink-soft leading-relaxed">
            UX research, usability testing, VOC synthesis, customer visits, feedback
            loops into product strategy. PX helps the company make better product
            decisions by making customer signal easier to see and act on.
          </p>
        </div>

        <!-- 05 Product Mastery & Community -->
        <div class="lesson-card">
          <div class="linocut-icon">
            <svg viewBox="0 0 80 80" xmlns="http://www.w3.org/2000/svg">
              <circle cx="26" cy="32" r="10" fill="#E13D0F" stroke="#02101D" stroke-width="2.5"/>
              <circle cx="54" cy="32" r="10" fill="#E13D0F" stroke="#02101D" stroke-width="2.5"/>
              <circle cx="40" cy="52" r="10" fill="#02101D"/>
