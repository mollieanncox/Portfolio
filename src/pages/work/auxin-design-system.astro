---
import Base from '../../layouts/Base.astro';
---
<Base
  title="Design System at Scale · Mollie Cox"
  description="Building a design system for a multi-product enterprise SaaS platform. Component library, governance, intake, and design-engineering ownership."
>
  <!-- ============================== -->
  <!-- HERO -->
  <!-- ============================== -->
  <section class="case-hero-dark">
    <div class="max-w-7xl mx-auto px-6 md:px-10 py-20 md:py-28 relative z-10">
      <a
        href="/#work"
        class="inline-flex items-center gap-2 font-mono text-xs uppercase tracking-[0.15em] text-cream/60 hover:text-orange transition-colors mb-16"
      >
        ← All work
      </a>
      <div class="grid grid-cols-1 md:grid-cols-12 gap-8 md:gap-12 items-start">
        <!-- Text column -->
        <div class="md:col-span-7">
          <p class="eyebrow-light mb-6">Branch · 2024 to 2026</p>
          <h1 class="font-display text-display-lg text-cream leading-[0.95] tracking-tight">
            A design system for a multi-product platform<span class="brand-period">.</span>
          </h1>
          <p class="mt-10 text-xl text-cream/80 leading-relaxed max-w-[48ch]">
            Building the design system that scales a complex enterprise SaaS surface
            through a multi-year product transformation. Component library, governance,
            intake process, dark mode readiness, and design-engineering ownership model.
          </p>
        </div>
        <!-- Artifact column: abstract component mosaic -->
        <div class="md:col-span-5 flex justify-center md:justify-end items-start mt-8 md:mt-0">
          <div class="case-hero-artifact w-full max-w-sm md:max-w-none">
            <svg viewBox="0 0 480 440" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="An abstract mosaic of geometric tiles in varying sizes and treatments, evoking a design system's vocabulary of primitives, tokens, and patterns">
              <!-- Subtle grid backdrop -->
              <g opacity="0.06">
                <line stroke="#F4EFE5" stroke-width="0.5" x1="80" y1="20" x2="80" y2="420"/>
                <line stroke="#F4EFE5" stroke-width="0.5" x1="160" y1="20" x2="160" y2="420"/>
                <line stroke="#F4EFE5" stroke-width="0.5" x1="240" y1="20" x2="240" y2="420"/>
                <line stroke="#F4EFE5" stroke-width="0.5" x1="320" y1="20" x2="320" y2="420"/>
                <line stroke="#F4EFE5" stroke-width="0.5" x1="400" y1="20" x2="400" y2="420"/>
              </g>
              <!-- Top row: large filled tile + two stacked small tiles -->
              <rect x="60" y="40" width="200" height="100" rx="4" fill="#E13D0F"/>
              <rect x="280" y="40" width="60" height="46" rx="4" fill="none" stroke="#F4EFE5" stroke-width="1.5"/>
              <rect x="360" y="40" width="60" height="46" rx="4" fill="#F4EFE5" opacity="0.9"/>
              <rect x="280" y="94" width="140" height="46" rx="23" fill="none" stroke="#F4EFE5" stroke-width="1.5" opacity="0.5"/>
              <!-- Middle row: opacity-scaled squares grid -->
              <g>
                <rect x="60" y="160" width="22" height="22" rx="2" fill="#F4EFE5" opacity="0.85"/>
                <rect x="88" y="160" width="22" height="22" rx="2" fill="#F4EFE5" opacity="0.55"/>
                <rect x="116" y="160" width="22" height="22" rx="2" fill="#F4EFE5" opacity="0.3"/>
                <rect x="144" y="160" width="22" height="22" rx="2" fill="none" stroke="#F4EFE5" stroke-width="1.5" opacity="0.5"/>
                <rect x="172" y="160" width="22" height="22" rx="2" fill="none" stroke="#F4EFE5" stroke-width="1.5" opacity="0.25"/>
                <rect x="60" y="190" width="22" height="22" rx="11" fill="#E13D0F"/>
                <rect x="88" y="190" width="22" height="22" rx="11" fill="#E13D0F" opacity="0.6"/>
                <rect x="116" y="190" width="22" height="22" rx="11" fill="#E13D0F" opacity="0.3"/>
                <rect x="144" y="190" width="22" height="22" rx="11" fill="none" stroke="#E13D0F" stroke-width="1.5"/>
                <rect x="172" y="190" width="22" height="22" rx="11" fill="none" stroke="#E13D0F" stroke-width="1.5" opacity="0.4"/>
              </g>
              <!-- Card-ish outlined tile with sub-elements -->
              <rect x="220" y="160" width="100" height="52" rx="4" fill="none" stroke="#F4EFE5" stroke-width="1.5"/>
              <rect x="234" y="174" width="48" height="6" rx="3" fill="#F4EFE5" opacity="0.85"/>
              <rect x="234" y="186" width="72" height="3" rx="1.5" fill="#F4EFE5" opacity="0.4"/>
              <rect x="234" y="194" width="60" height="3" rx="1.5" fill="#F4EFE5" opacity="0.4"/>
              <!-- Purple accent block -->
              <rect x="340" y="160" width="80" height="52" rx="4" fill="#9B40C4" opacity="0.85"/>
              <!-- Spacing rhythm row, descending cream bars -->
              <g transform="translate(0, 232)">
                <rect x="60" y="0" width="6" height="48" fill="#F4EFE5" opacity="0.85"/>
                <rect x="74" y="12" width="6" height="36" fill="#F4EFE5" opacity="0.65"/>
                <rect x="88" y="20" width="6" height="28" fill="#F4EFE5" opacity="0.5"/>
                <rect x="102" y="28" width="6" height="20" fill="#F4EFE5" opacity="0.35"/>
                <rect x="116" y="36" width="6" height="12" fill="#F4EFE5" opacity="0.25"/>
              </g>
              <!-- Ascending orange bars, mirrored -->
              <g transform="translate(0, 232)">
                <rect x="148" y="36" width="6" height="12" fill="#E13D0F" opacity="0.4"/>
                <rect x="162" y="28" width="6" height="20" fill="#E13D0F" opacity="0.55"/>
                <rect x="176" y="20" width="6" height="28" fill="#E13D0F" opacity="0.7"/>
                <rect x="190" y="12" width="6" height="36" fill="#E13D0F" opacity="0.85"/>
                <rect x="204" y="0" width="6" height="48" fill="#E13D0F"/>
              </g>
              <!-- Long outlined horizontal tile -->
              <rect x="220" y="232" width="200" height="48" rx="4" fill="none" stroke="#F4EFE5" stroke-width="1.5" opacity="0.5"/>
              <!-- Bottom row: radius scale + medium filled tile + stacked outlined tiles -->
              <g>
                <rect x="60" y="300" width="32" height="32" rx="0" fill="#F4EFE5" opacity="0.7"/>
                <rect x="100" y="300" width="32" height="32" rx="4" fill="#F4EFE5" opacity="0.7"/>
                <rect x="140" y="300" width="32" height="32" rx="8" fill="#F4EFE5" opacity="0.7"/>
                <rect x="180" y="300" width="32" height="32" rx="16" fill="#F4EFE5" opacity="0.7"/>
              </g>
              <rect x="230" y="300" width="90" height="64" rx="4" fill="#E13D0F" opacity="0.7"/>
              <rect x="340" y="300" width="80" height="32" rx="4" fill="none" stroke="#F4EFE5" stroke-width="1.5"/>
              <rect x="340" y="344" width="80" height="20" rx="4" fill="none" stroke="#F4EFE5" stroke-width="1.5" opacity="0.5"/>
            </svg>
          </div>
        </div>
      </div>
      <div class="mt-20 grid grid-cols-2 md:grid-cols-4 gap-6 pt-10 border-t border-cream/15 relative z-10">
        <div>
          <p class="eyebrow-light mb-2">Role</p>
          <p class="text-cream">Sr. Director, Product Experience</p>
        </div>
        <div>
          <p class="eyebrow-light mb-2">Duration</p>
          <p class="text-cream">Multi-year program</p>
        </div>
        <div>
          <p class="eyebrow-light mb-2">Surface</p>
          <p class="text-cream">Multi-product platform</p>
        </div>
        <div>
          <p class="eyebrow-light mb-2">Adoption</p>
          <p class="text-cream">94% across product surface</p>
        </div>
      </div>
    </div>
  </section>
  <!-- =============================== -->
  <!-- The problem -->
  <!-- =============================== -->
  <section class="grid-backdrop border-b border-ink/10 overflow-hidden">
    <div class="grid-backdrop-band-top"></div>
    <div class="grid-backdrop-band-bottom"></div>
    <div class="max-w-7xl mx-auto px-6 md:px-10 py-24 md:py-32 relative z-10">
      <p class="eyebrow mb-3">The problem</p>
      <h2 class="font-display text-display-md text-ink leading-tight max-w-[28ch] mb-12">
        A growing platform, an aging system.
      </h2>
      <div class="grid md:grid-cols-2 gap-12 max-w-5xl">
        <p class="text-xl text-ink-soft leading-relaxed">
          Branch's product surface had grown across multiple products and customer
          segments. The existing design system was struggling to keep up: components
          had drifted, custom one-offs had multiplied, design tokens were
          inconsistent, dark mode was unsupported, and Figma-to-code alignment was
          unreliable.
        </p>
        <p class="text-xl text-ink-soft leading-relaxed">
          The cost was real. Designers and engineers spent significant time
          recreating what should have been shared infrastructure. New product
          modernization work risked compounding the inconsistency. Customer-facing
          UI quality varied across products. Without a stronger system, every new
          product surface added entropy.
        </p>
      </div>
    </div>
  </section>
  <!-- =============================== -->
  <!-- THREE-PILLAR APPROACH -->
  <!-- =============================== -->
  <section class="max-w-7xl mx-auto px-6 md:px-10 py-24 md:py-32">
    <p class="eyebrow mb-3">The approach</p>
    <h2 class="font-display text-display-md text-ink leading-tight max-w-[26ch] mb-16">
      Foundation, governance, adoption.
    </h2>
    <div class="pillar-grid">
      <!-- Foundation -->
      <div class="pillar">
        <div class="pillar-icon">
          <!-- Foundation / stacked layers -->
          <svg viewBox="0 0 80 80" xmlns="http://www.w3.org/2000/svg">
            <rect x="10" y="52" width="60" height="14" fill="#02101D"/>
            <rect x="14" y="38" width="52" height="14" fill="#E13D0F" stroke="#02101D" stroke-width="2.5"/>
            <rect x="18" y="24" width="44" height="14" fill="#E13D0F" stroke="#02101D" stroke-width="2.5"/>
            <rect x="22" y="14" width="36" height="10" fill="#02101D"/>
            <line x1="18" y1="32" x2="62" y2="32" stroke="#F4EFE5" stroke-width="1.5" opacity="0.5"/>
            <line x1="14" y1="46" x2="66" y2="46" stroke="#F4EFE5" stroke-width="1.5" opacity="0.5"/>
          </svg>
        </div>
        <div class="pillar-meta">
          <p class="eyebrow mb-3">Foundation</p>
          <h3 class="font-display text-3xl text-ink leading-tight">
            Rebuild the building blocks.
          </h3>
        </div>
        <div class="pillar-body">
          <p class="text-ink-soft leading-relaxed">
            Typography revisions, badge component corrections, design token
            normalization, dark mode feasibility, and a production audit that mapped
            every inconsistency back to a system gap. The work of making the
            primitives right so everything built on top could trust them.
          </p>
        </div>
        <div class="pillar-tagline"></div>
      </div>
      <!-- Governance -->
      <div class="pillar">
        <div class="pillar-icon">
          <!-- Governance / scales -->
          <svg viewBox="0 0 80 80" xmlns="http://www.w3.org/2000/svg">
            <rect x="36" y="12" width="8" height="50" fill="#02101D"/>
            <line x1="14" y1="22" x2="66" y2="22" stroke="#02101D" stroke-width="3"/>
            <path d="M14 22 L 8 38 L 26 38 L 20 22 Z" fill="#E13D0F" stroke="#02101D" stroke-width="2.5" stroke-linejoin="round"/>
            <path d="M66 22 L 60 38 L 78 38 L 72 22 Z" fill="#E13D0F" stroke="#02101D" stroke-width="2.5" stroke-linejoin="round"/>
            <rect x="28" y="62" width="24" height="6" fill="#02101D"/>
          </svg>
        </div>
        <div class="pillar-meta">
          <p class="eyebrow-voice mb-3">Governance</p>
          <h3 class="font-display text-3xl text-ink leading-tight">
            Rules, intake, ownership.
          </h3>
        </div>
        <div class="pillar-body">
          <p class="text-ink-soft leading-relaxed">
            A formal governance model with a moratorium on custom components, a
            structured intake process for new requests, and a defined ownership
            model between design and engineering. Without governance, a design
            system entropies back into a component zoo.
          </p>
        </div>
        <div class="pillar-tagline">
          <p class="font-display text-2xl italic text-orange">"No new custom components."</p>
        </div>
      </div>
      <!-- Adoption -->
      <div class="pillar">
        <div class="pillar-icon">
          <!-- Adoption / network expansion -->
          <svg viewBox="0 0 80 80" xmlns="http://www.w3.org/2000/svg">
            <circle cx="40" cy="40" r="8" fill="#E13D0F" stroke="#02101D" stroke-width="2.5"/>
            <circle cx="16" cy="16" r="5" fill="#02101D"/>
            <circle cx="64" cy="16" r="5" fill="#02101D"/>
            <circle cx="16" cy="64" r="5" fill="#02101D"/>
            <circle cx="64" cy="64" r="5" fill="#02101D"/>
            <circle cx="16" cy="40" r="4" fill="#E13D0F" stroke="#02101D" stroke-width="2"/>
            <circle cx="64" cy="40" r="4" fill="#E13D0F" stroke="#02101D" stroke-width="2"/>
            <line x1="22" y1="20" x2="36" y2="36" stroke="#02101D" stroke-width="2"/>
            <line x1="58" y1="20" x2="44" y2="36" stroke="#02101D" stroke-width="2"/>
            <line x1="22" y1="60" x2="36" y2="44" stroke="#02101D" stroke-width="2"/>
            <line x1="58" y1="60" x2="44" y2="44" stroke="#02101D" stroke-width="2"/>
            <line x1="20" y1="40" x2="32" y2="40" stroke="#02101D" stroke-width="2"/>
            <line x1="48" y1="40" x2="60" y2="40" stroke="#02101D" stroke-width="2"/>
          </svg>
        </div>
        <div class="pillar-meta">
          <p class="eyebrow mb-3">Adoption</p>
          <h3 class="font-display text-3xl text-ink leading-tight">
            Make the system the path of least resistance.
          </h3>
        </div>
        <div class="pillar-body">
          <p class="text-ink-soft leading-relaxed">
            Public documentation, Storybook integration, a canonical spec repository
            for component documentation, training sessions, and integrating the system
            into the broader product modernization program. Adoption isn't enforced.
            It's earned by making the system easier than the alternative.
          </p>
        </div>
        <div class="pillar-tagline"></div>
      </div>
    </div>
  </section>

  <!-- =============================== -->
  <!-- THE SYSTEM (light + dark canvas proof) -->
  <!-- =============================== -->
  <section class="bg-ink py-24 md:py-32">
    <div class="max-w-7xl mx-auto px-6 md:px-10">
      <p class="eyebrow-light mb-3">The system itself</p>
      <h2 class="font-display text-display-md text-cream leading-tight max-w-[28ch] mb-6">
        Light. Dark. One system<span class="text-orange">.</span>
      </h2>
      <p class="text-lg text-cream/70 leading-relaxed max-w-reading mb-16">
        Inputs. Buttons. Checkboxes. Tabs. Dialogs. Alerts. Dropdowns. Pagination. Empty states.
        Progress. Toasts. Tokens for primary, accent, border, destructive, positive, caution,
        magenta, purple, and orange in foreground and background variants. All shipped from one
        source of truth across both themes.
      </p>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8">
        <!-- Light theme canvas -->
        <figure>
          <button
            type="button"
            data-modal-trigger
            data-modal-src="/auxin/system-light.png"
            data-modal-caption="The design system. Light theme. Components and color tokens shown together on a single canvas."
            class="group block relative w-full overflow-hidden cursor-zoom-in transition-all hover:shadow-2xl"
            style="border-radius: 14px;"
            aria-label="View light theme design system at full size"
          >
            <img
              src="/auxin/system-light.png"
              alt="Branch design system overview in light theme showing the full component library: inputs, buttons, checkboxes, radio buttons, tabs, dialogs, alerts, dropdowns, pagination, empty states, progress bars, toasts, and a complete color token palette with primary, accent, border, destructive, positive, caution, magenta, purple, and orange variants"
              class="w-full h-auto block transition-transform group-hover:scale-[1.02] pointer-events-none"
              loading="lazy"
            />
            <span class="absolute top-4 right-4 bg-ink/85 text-cream font-mono text-[10px] uppercase tracking-[0.12em] px-2.5 py-1.5 rounded opacity-0 group-hover:opacity-100 transition-opacity backdrop-blur-sm pointer-events-none">View full ↗</span>
          </button>
          <figcaption class="mt-5 flex items-baseline gap-3">
            <p class="font-mono text-[11px] uppercase tracking-[0.18em] text-orange font-semibold">Light theme</p>
            <p class="text-sm text-cream/60">Default surface</p>
          </figcaption>
        </figure>
        <!-- Dark theme canvas -->
        <figure>
          <button
            type="button"
            data-modal-trigger
            data-modal-src="/auxin/system-dark.png"
            data-modal-caption="The design system. Dark theme. Same components, same tokens, theme-aware foreground and background pairs."
            class="group block relative w-full overflow-hidden cursor-zoom-in transition-all hover:shadow-2xl"
            style="border-radius: 14px;"
            aria-label="View dark theme design system at full size"
          >
            <img
              src="/auxin/system-dark.png"
              alt="Branch design system overview in dark theme showing the same component library and color tokens applied to a dark surface, demonstrating theme-aware foreground and background pairs across the whole system"
              class="w-full h-auto block transition-transform group-hover:scale-[1.02] pointer-events-none"
              loading="lazy"
            />
            <span class="absolute top-4 right-4 bg-cream/85 text-ink font-mono text-[10px] uppercase tracking-[0.12em] px-2.5 py-1.5 rounded opacity-0 group-hover:opacity-100 transition-opacity backdrop-blur-sm pointer-events-none">View full ↗</span>
          </button>
          <figcaption class="mt-5 flex items-baseline gap-3">
            <p class="font-mono text-[11px] uppercase tracking-[0.18em] text-orange font-semibold">Dark theme</p>
            <p class="text-sm text-cream/60">Theme-aware tokens</p>
          </figcaption>
        </figure>
      </div>
      <p class="mt-10 font-mono text-xs uppercase tracking-[0.15em] text-cream/40 text-center max-w-reading mx-auto">
        Click either canvas to view at full size.
      </p>
    </div>
  </section>

  <!-- =============================== -->
  <!-- Operational artifacts grid -->
  <!-- =============================== -->
  <section class="bg-cream-warm/40 border-y border-ink/10 py-24 md:py-32">
    <div class="max-w-7xl mx-auto px-6 md:px-10">
      <p class="eyebrow mb-3">The operational artifacts</p>
      <h2 class="font-display text-display-md text-ink leading-tight max-w-[28ch] mb-16">
        What we built, what we shipped, what we measured.
      </h2>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-4 md:gap-6">
        {[
          {
            num: '01',
            name: 'Component library',
            desc: 'Reusable components across primitives, composites, and patterns. Versioned, documented, and synchronized between Figma and code.',
          },
          {
            num: '02',
            name: 'Storybook integration',
            desc: 'Live component playground for engineers. Documentation, props, states, and accessibility specs in one place.',
          },
          {
            num: '03',
            name: 'Canonical spec repository',
            desc: 'Single source of truth for component specifications, design tokens, and usage guidelines accessible to design and engineering.',
          },
          {
            num: '04',
            name: 'Public documentation',
            desc: 'Public-facing system documentation for designers, engineers, and product partners. Adoption requires accessibility.',
          },
          {
            num: '05',
            name: 'Governance model',
            desc: 'Formal governance with named owners, decision rights, and a moratorium on new custom components. Rules of the road.',
          },
          {
            num: '06',
            name: 'Intake process',
            desc: 'Structured intake for new component requests. Triage, prioritization, and a defined path from request to release.',
          },
          {
            num: '07',
            name: 'Production audit',
            desc: 'Full audit of live product surfaces to map system drift, inconsistency, and the cost of custom one-offs.',
          },
          {
            num: '08',
            name: 'Dark mode readiness',
            desc: 'Feasibility assessment, token architecture, and roadmap for dark mode support across the platform.',
          },
          {
            num: '09',
            name: 'Training sessions',
            desc: 'Structured onboarding and training for designers and engineers adopting the system. Reduces support burden.',
          },
        ].map((item) => (
          <div class="p-6 md:p-7 bg-cream border border-ink/10 h-full flex flex-col" style="border-radius: 12px;">
            <p class="font-mono text-xs text-orange uppercase tracking-wider mb-3">{item.num}</p>
            <p class="font-display text-xl text-ink mb-3 leading-tight">{item.name}</p>
            <p class="text-sm text-ink-soft leading-relaxed">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>
  <!-- =============================== -->
  <!-- THE GOVERNANCE FLOW (intake → triage → tracked → done) -->
  <!-- =============================== -->
  <section class="max-w-7xl mx-auto px-6 md:px-10 py-24 md:py-32">
    <p class="eyebrow mb-3">The governance flow</p>
    <h2 class="font-display text-display-md text-ink leading-tight max-w-[28ch] mb-12">
      How a request becomes a tracked, finished system change.
    </h2>
    <p class="text-lg text-ink-soft leading-relaxed max-w-reading mb-16">
      Before governance, every team was creating their own custom components and
      nothing was getting logged. The system was reverting to the problem the system
      was supposed to solve. The fix was a real intake with three defined paths, a
      triage gate, and auto-generated tracking work per request type. The rule that
      made it work was simple: no new custom components.
    </p>
    <!-- Governance flow diagram (simplified) -->
    <div class="mb-16 p-8 md:p-12 bg-cream border border-ink/10" style="border-radius: 16px;">
      <svg viewBox="0 0 1000 380" xmlns="http://www.w3.org/2000/svg" class="w-full h-auto" role="img" aria-label="Governance flow diagram. A single intake form feeds into a triage gate. The triage gate routes into three defined paths: Path A for new components, Path B for component changes, and Path C for bug fixes. All three paths converge into a Done state. Sub-issues are auto-generated per path and tracked in one source of truth.">
        <!-- Stage 01: Intake -->
        <g>
          <rect x="40" y="160" width="160" height="60" rx="8" fill="#FFFFFF" stroke="#02101D" stroke-width="1.5"/>
          <text x="56" y="184" font-family="'JetBrains Mono', ui-monospace, monospace" font-size="10" letter-spacing="2" fill="#E13D0F">01 · INTAKE</text>
          <text x="56" y="206" font-family="'new-spirit', Georgia, serif" font-size="18" fill="#02101D" font-weight="500">One form</text>
        </g>
        <!-- Arrow intake to triage -->
        <g stroke="#02101D" stroke-width="1.5" fill="none">
          <line x1="200" y1="190" x2="240" y2="190"/>
          <polyline points="235,184 240,190 235,196"/>
        </g>
        <!-- Stage 02: Triage (the gate, dominant element) -->
        <g>
          <rect x="240" y="140" width="180" height="100" rx="8" fill="#E13D0F"/>
          <text x="256" y="166" font-family="'JetBrains Mono', ui-monospace, monospace" font-size="10" letter-spacing="2" fill="#F4EFE5">02 · TRIAGE</text>
          <text x="256" y="194" font-family="'new-spirit', Georgia, serif" font-size="22" fill="#F4EFE5" font-weight="500">The gate</text>
          <text x="256" y="220" font-family="'new-spirit', Georgia, serif" font-size="11" fill="#F4EFE5" opacity="0.85" font-style="italic">3 paths out</text>
        </g>
        <!-- 3 diverging arrows from triage to paths -->
        <g stroke="#02101D" stroke-width="1.5" fill="none">
          <path d="M 420 170 Q 460 170 460 90 L 500 90"/>
