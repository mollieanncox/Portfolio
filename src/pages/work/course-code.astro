---
import Base from '../../layouts/Base.astro';
---
<Base
  title="Course Code · Mollie Cox"
  description="An AI-native consumer product, built solo with an AI co-founder. 18K+ courses indexed. 5.2K active users in 30 days. 100% organic growth. Live at coursecode.golf."
>
  <!-- ============================== -->
  <!-- HERO -->
  <!-- ============================== -->
  <section class="case-hero-dark">
    <div class="max-w-7xl mx-auto px-6 md:px-10 py-20 md:py-32 relative z-10">
      <a
        href="/#work"
        class="inline-flex items-center gap-2 font-mono text-xs uppercase tracking-[0.15em] text-cream/60 hover:text-orange transition-colors mb-16"
      >
        ← All work
      </a>
      <div class="grid md:grid-cols-12 gap-8 md:gap-16 items-center">
        <div class="md:col-span-7">
          <p class="eyebrow-light mb-6">Course Code · 2026 to present</p>
          <h1 class="font-display text-display-lg text-cream leading-[0.95] tracking-tight">
            An AI-native consumer product<span class="brand-period">.</span>
          </h1>
          <p class="mt-10 text-xl text-cream/80 leading-relaxed max-w-[40ch]">
            Built solo with an AI co-founder, as a deliberate experiment.
            No Figma. No wireframes. No mocks. Just brief, prompt, judge, ship.
            18K+ courses indexed. 5.2K users in 30 days. 100% organic growth.
            And one question driving all of it: what's load-bearing, and what's anxious?
          </p>
          <div class="mt-10 flex flex-wrap gap-4">
            <a
              href="https://coursecode.golf"
              target="_blank"
              rel="noopener"
              class="inline-flex items-center gap-2 px-6 py-3 bg-orange text-cream font-mono text-xs uppercase tracking-[0.15em] hover:bg-orange-deep transition-colors"
              style="border-radius: 999px;"
            >
              See it live →
            </a>
            <a
              href="/ai"
              class="inline-flex items-center gap-2 px-6 py-3 border border-cream/30 text-cream font-mono text-xs uppercase tracking-[0.15em] hover:border-orange hover:text-orange transition-colors"
              style="border-radius: 999px;"
            >
              Read the AI operating model →
            </a>
          </div>
        </div>
        <!-- The fox: SVG with brand orange #E13D0F baked in -->
        <div class="md:col-span-5 flex justify-center md:justify-end">
          <svg viewBox="0 0 277 301" xmlns="http://www.w3.org/2000/svg" class="w-full max-w-xs md:max-w-sm">
            <path d="M157.433 0.0194147C160.064 0.28246 161.676 2.94593 163.024 5.90516C174.636 31.2571 178.058 58.7139 177.992 87.0253C214.307 112.772 199.242 143.253 239.011 154.663L268.419 163.081C274.142 164.725 277.234 169.887 276.148 175.74C272.267 196.554 258.681 212.173 239.504 220.887C220.326 229.6 189.406 232.1 183.452 250.02C181.84 254.887 181.018 259.819 180.788 264.817L180.67 267.096C180.578 273.283 181.289 279.521 182.33 285.721C179.573 283.247 175.416 281.701 170.458 280.891C170.317 279.63 170.194 278.361 170.097 277.082C169.866 274.155 169.769 271.163 169.867 268.105L169.995 265.711C170.379 258.307 171.814 250.388 174.867 241.602C168.255 238.873 147.532 257.714 150.689 246.042C150.854 245.45 151.61 244.957 152.63 244.036C174.636 224.011 204.8 224.503 229.603 213.883C209.866 214.869 192.005 217.072 173.814 211.581C171.479 210.858 171.446 207.998 172.301 207.142C177.794 201.651 202.761 214.903 240.228 202.572C247.07 200.303 252.925 196.719 257.136 191.458C252.202 188.729 249.274 185.473 246.248 180.969L233.32 186.657C205.36 198.988 150.623 172.616 96.9395 203.525C79.1437 213.784 66.4796 229.141 59.21 248.541C71.2821 243.806 79.9003 236.539 93.2881 234.829L80.0322 253.802C79.177 255.051 76.8417 256.728 78.3877 258.011C80.9219 260.147 109.275 245.187 120.064 247.685C113.222 257.517 107.4 268.961 102.663 281.028C100.208 287.265 98.0441 293.674 96.1797 300.12C94.2075 297.729 89.4431 292.472 79.5605 282.119C70.127 272.236 57.3445 262.334 46.5098 254.907C41.0905 251.193 36.1506 248.092 32.3516 245.918C30.453 244.831 28.8327 243.973 27.5771 243.385C26.95 243.091 26.4061 242.861 25.96 242.703C25.5303 242.551 25.1376 242.447 24.8359 242.447C22.9579 242.447 21.5809 243.475 20.1895 244.663C18.7753 245.87 17.299 247.285 15.1299 248.37H15.1289C14.7446 248.562 13.3407 249.316 11.1123 250.156C10.9008 250.236 9.71064 250.723 7.72363 251.541C8.84172 248.237 9.90812 244.805 10.9395 241.224C11.9443 237.736 12.9182 234.108 13.8818 230.324C7.69769 231.048 5.65784 235.125 0 233.086C8.58539 216.217 15.4935 199.546 18.0264 180.508C19.2435 171.268 24.2434 160.844 23.0264 151.638C21.0198 136.545 16.9406 122.702 16.6445 107.083C16.1182 81.0735 19.21 55.7217 25.7559 30.6659C26.4466 28.0354 28.355 25.9306 29.8682 25.3388C32.3681 24.3523 35.6573 25.2074 38.1572 26.9501C59.1109 41.8784 76.8741 59.108 92.7949 79.3632C98.9462 78.8371 106.611 77.8838 111.282 74.6942C115.46 61.3439 144.538 -1.26276 157.433 0.0194147ZM53.6182 206.945C44.8354 210.891 39.3743 218.289 35.5586 226.575C44.1111 223.418 50.7563 216.744 53.6182 206.945ZM49.9004 194.186C52.0052 182.219 34.9018 205.727 35.3945 210.496C41.8088 206.452 45.8873 200.697 49.9004 194.186ZM41.4473 175.641C37.2697 182.053 33.9798 187.972 32.1377 195.699C39.1113 190.767 42.6315 183.895 41.4473 175.641ZM100.756 183.5C89.8679 180.508 83.9469 188.104 76.3154 192.773C73.4207 192.905 75.4928 194.515 78.1572 193.989C86.2492 190.833 94.1113 187.544 100.756 183.5ZM102.86 172.058C93.3542 167.29 84.6705 171.498 77.5654 177.614C87.1702 177.154 94.4726 173.998 102.86 172.058ZM143.223 141.477C133.848 141.642 129.604 147.692 122.631 150.257C120.295 151.112 117.828 153.085 119.045 155.288C119.252 155.654 140.888 165.283 144.275 162.85L144.242 162.817C139.966 154.038 140.032 148.35 143.223 141.477ZM156.841 144.634C157.499 152.229 156.775 156.965 154.341 162.653C161.347 162.357 166.248 160.91 172.005 157.622C166.577 151.309 162.729 148.152 156.841 144.634ZM39.21 44.1141C29.3746 70.1894 38.2559 119.643 49.1768 143.943C62.6964 139.142 33.7827 93.6996 51.4141 75.1542L52.4336 95.7714C56.1073 93.5746 55.4637 88.9593 59.4062 89.0634C59.472 95.4096 56.1833 98.7313 58.749 104.025C61.249 101.921 60.6905 97.777 65.5918 97.0536C63.8155 104.978 62.4666 111.949 63.6836 120.728C71.2162 112.738 78.5846 106.294 88.8145 100.605C74.5712 78.6074 58.3216 60.2592 39.21 44.1141ZM195.787 126.351C193.452 133.125 197.334 140.031 203.584 142.168C202.367 135.986 200.557 130.889 195.787 126.351ZM140.295 104.387C146.578 107.773 150.656 113.331 158.847 115.008C155.327 107.116 147.861 105.274 140.295 104.387ZM154.966 100.572C159.143 105.307 162.926 109.582 169.209 113.002C167.926 106.787 162.531 101.427 154.966 100.572ZM156.873 21.3602C148.748 38.8533 145.097 56.5109 143.519 75.5165C152.3 77.6865 159.175 80.8749 168.187 80.9413C166.411 60.2707 164.731 40.52 156.873 21.3602Z" fill="#E13D0F"/>
          </svg>
        </div>
      </div>
      <div class="mt-20 grid grid-cols-2 md:grid-cols-4 gap-6 pt-10 border-t border-cream/15 relative z-10">
        <div>
          <p class="eyebrow-light mb-2">Role</p>
          <p class="text-cream">Founder · Product · Design</p>
        </div>
        <div>
          <p class="eyebrow-light mb-2">Duration</p>
          <p class="text-cream">10 weeks</p>
        </div>
        <div>
          <p class="eyebrow-light mb-2">Team</p>
          <p class="text-cream">One human, one AI</p>
        </div>
        <div>
          <p class="eyebrow-light mb-2">Status</p>
          <p class="text-cream">Live · Phase 1 shipped</p>
        </div>
      </div>
    </div>
  </section>
  <!-- =============================== -->
  <!-- Big stats with grid backdrop. Numbers in BRAND ORANGE, no periods. -->
  <!-- =============================== -->
  <section class="grid-backdrop border-b border-ink/10 overflow-hidden">
    <div class="grid-backdrop-band-top"></div>
    <div class="grid-backdrop-band-bottom"></div>
    <div class="max-w-7xl mx-auto px-6 md:px-10 py-20 md:py-28 relative z-10">
      <p class="eyebrow mb-12">Live, as of May 2026</p>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-x-6 gap-y-12">
        <div>
          <p class="stat-hero">5.2K</p>
          <p class="stat-hero-label">Active users (30 days)</p>
        </div>
        <div>
          <p class="stat-hero">18K+</p>
          <p class="stat-hero-label">Courses indexed</p>
        </div>
        <div>
          <p class="stat-hero">+96%</p>
          <p class="stat-hero-label">MoM user growth</p>
        </div>
        <div>
          <p class="stat-hero">$0</p>
          <p class="stat-hero-label">Paid acquisition spend</p>
        </div>
      </div>
      <!-- The artifact-stack punchline -->
      <div class="mt-12 pt-8 border-t border-ink/10 flex flex-wrap items-baseline gap-x-6 gap-y-2">
        <p class="font-mono text-[11px] uppercase tracking-[0.18em] text-orange font-semibold">By the way</p>
        <p class="font-display text-lg md:text-xl text-ink leading-snug">
          0 Figma files. 0 wireframes. 0 mocks. 0 prototypes. The artifact stack collapsed by design<span class="text-orange">.</span>
        </p>
      </div>
    </div>
  </section>
  <!-- =============================== -->
  <!-- THE EXPERIMENT (the load-bearing thesis) -->
  <!-- =============================== -->
  <section class="bg-ink text-cream py-24 md:py-32">
    <div class="max-w-7xl mx-auto px-6 md:px-10">
      <p class="eyebrow-light mb-6">The experiment</p>
      <h2 class="font-display text-cream leading-[1.0] tracking-tight max-w-[24ch] mb-12" style="font-size: clamp(2rem, 6vw, 5.5rem);">
        What's load-bearing<span class="text-orange">?</span><br/>
        What's anxious<span class="text-orange">?</span>
      </h2>
      <div class="grid md:grid-cols-12 gap-8 md:gap-10">
        <!-- Lead copy column -->
        <div class="md:col-span-4">
          <p class="text-lg text-cream/85 leading-relaxed mb-5">
            Course Code is a real consumer product. It is also a deliberate stress test
            on the design discipline. How far could AI take a design role if I only
            stepped in for judgment?
          </p>

          <!-- The hypothesis: the load-bearing claim being tested -->
          <div class="my-8 py-6 border-y border-orange/30">
            <p class="font-mono text-[10px] uppercase tracking-[0.2em] text-orange font-semibold mb-3">The hypothesis</p>
            <p class="font-display text-cream leading-[1.1] tracking-tight" style="font-size: clamp(1.5rem, 2.4vw, 2rem);">
              AI can execute<span class="text-orange">.</span><br/>
              Taste cannot be delegated<span class="text-orange">.</span>
            </p>
          </div>

          <p class="text-lg text-cream/85 leading-relaxed mb-5">
            The rule was specific. No Figma. No wireframes. No mocks. No prototypes.
            No spec docs translating intent for engineers. Brief, prompt, judge, ship.
          </p>
          <p class="text-lg text-cream/85 leading-relaxed mb-5">
            The test: which artifacts in the design process are
            <span class="text-orange font-semibold">load-bearing</span>,
            the ones the design itself depends on, and which are
            <span class="text-orange font-semibold">anxious</span>,
            the ones we produced to protect against a handoff failure that hadn't happened yet?
          </p>
          <p class="text-lg text-cream leading-relaxed font-display italic">
            The verdict is <span class="md:hidden">below</span><span class="hidden md:inline">to the right</span>.
          </p>
        </div>

        <!-- ANXIOUS column: what collapsed -->
        <div class="md:col-span-4">
          <div class="border border-cream/15 p-6 md:p-8 h-full flex flex-col" style="border-radius: 14px; background: rgba(244,239,229,0.03);">
            <div class="mb-2">
              <p class="font-mono text-[11px] uppercase tracking-[0.18em] text-orange font-semibold">Anxious</p>
              <p class="text-xs text-cream/55 leading-snug mt-1.5">Produced to defend against a handoff failure. Translation insurance between stations.</p>
            </div>
            <div class="mt-6 pt-6 border-t border-cream/15">
              <p class="font-mono text-[10px] uppercase tracking-[0.15em] text-cream/60 mb-4">What collapsed</p>
              <ul class="space-y-3">
                <li class="flex items-baseline gap-3 text-cream/50 line-through decoration-orange/60 decoration-2">
                  <span class="font-mono text-[10px] text-orange/70 not-line-through no-underline">01</span>
                  <span class="font-display text-lg">Wireframes</span>
                </li>
                <li class="flex items-baseline gap-3 text-cream/50 line-through decoration-orange/60 decoration-2">
                  <span class="font-mono text-[10px] text-orange/70 not-line-through no-underline">02</span>
                  <span class="font-display text-lg">Hi-fi mocks</span>
                </li>
                <li class="flex items-baseline gap-3 text-cream/50 line-through decoration-orange/60 decoration-2">
                  <span class="font-mono text-[10px] text-orange/70 not-line-through no-underline">03</span>
                  <span class="font-display text-lg">Prototypes</span>
                </li>
                <li class="flex items-baseline gap-3 text-cream/50 line-through decoration-orange/60 decoration-2">
                  <span class="font-mono text-[10px] text-orange/70 not-line-through no-underline">04</span>
                  <span class="font-display text-lg">Handoff specs</span>
                </li>
                <li class="flex items-baseline gap-3 text-cream/50 line-through decoration-orange/60 decoration-2">
                  <span class="font-mono text-[10px] text-orange/70 not-line-through no-underline">05</span>
                  <span class="font-display text-lg">Mock-explainer decks</span>
                </li>
              </ul>
            </div>
            <div class="mt-auto pt-8">
              <p class="text-xs text-cream/55 leading-relaxed italic">
                These existed because each station didn't trust the next.
                AI dissolves the handoff. The defenses can come down.
              </p>
            </div>
          </div>
        </div>

        <!-- LOAD-BEARING column: what stayed -->
        <div class="md:col-span-4">
          <div class="border-2 border-orange p-6 md:p-8 h-full flex flex-col" style="border-radius: 14px; background: rgba(225,61,15,0.06);">
            <div class="mb-2">
              <p class="font-mono text-[11px] uppercase tracking-[0.18em] text-orange font-semibold">Load-bearing</p>
              <p class="text-xs text-cream/70 leading-snug mt-1.5">The design itself depends on these. They cannot be delegated, automated, or rushed.</p>
            </div>
            <div class="mt-6 pt-6 border-t border-orange/30">
              <p class="font-mono text-[10px] uppercase tracking-[0.15em] text-cream/60 mb-4">What stayed</p>
              <ul class="space-y-5">
                <li class="flex items-baseline gap-3">
                  <span class="font-mono text-[10px] text-orange font-semibold">01</span>
                  <div>
                    <p class="font-display text-lg text-cream leading-tight">Taste.</p>
                    <p class="text-xs text-cream/65 leading-snug mt-1">Knowing which one of ninety-nine ships. The years-of-staring-at-pixels skill.</p>
                  </div>
                </li>
                <li class="flex items-baseline gap-3">
                  <span class="font-mono text-[10px] text-orange font-semibold">02</span>
                  <div>
                    <p class="font-display text-lg text-cream leading-tight">Judgment.</p>
                    <p class="text-xs text-cream/65 leading-snug mt-1">The calls about what the product is, who it is for, and what it refuses to be.</p>
                  </div>
                </li>
                <li class="flex items-baseline gap-3">
                  <span class="font-mono text-[10px] text-orange font-semibold">03</span>
                  <div>
                    <p class="font-display text-lg text-cream leading-tight">The brief.</p>
                    <p class="text-xs text-cream/65 leading-snug mt-1">The new artifact that carries intent directly into the build. The brief IS the design.</p>
                  </div>
                </li>
              </ul>
            </div>
            <div class="mt-auto pt-8">
              <p class="text-xs text-cream/70 leading-relaxed italic">
                Everything else compresses. These three got more important, not less.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
  <!-- =============================== -->
  <!-- THE COST (taste and judgment as irreducible) -->
  <!-- =============================== -->
  <section class="bg-cream-warm/40 border-y border-ink/10 py-24 md:py-32">
    <div class="max-w-7xl mx-auto px-6 md:px-10">
    <p class="eyebrow mb-6">The cost</p>
    <h2 class="font-display text-ink leading-[1.0] tracking-tight max-w-[26ch] mb-12" style="font-size: clamp(2rem, 6vw, 5.5rem);">
      AI collapsed the stack.<br/>
      <span class="text-orange">It did not collapse the work.</span>
    </h2>
    <div class="grid md:grid-cols-12 gap-8 md:gap-16">
      <div class="md:col-span-7 max-w-reading">
        <p class="text-xl text-ink-soft leading-relaxed mb-6">
          Course Code is live. It is not pixel perfect. The screenshots on this
          page have spacing I would still fix, copy I would still rewrite, edge
          cases I would still polish. What you are seeing is the result of
          hundreds of hours of judgment calls AI could not make for me.
        </p>
        <p class="text-xl text-ink-soft leading-relaxed mb-6">
          The artifact stack existed because each station distrusted the next.
          Wireframes protected designers from their own future selves. Mocks
          protected engineering from interpretive ambiguity. Specs protected
          the build from edge cases. Every artifact was insurance against a
          handoff failure. AI dissolves most of those handoffs by carrying
          intent directly into code. The defenses become unnecessary. The
          irreducible part of the work steps forward.
        </p>
        <p class="text-xl text-ink-soft leading-relaxed mb-6">
          Every prompt landed because the brief was tight. Every output shipped
          because I rejected the ninety-nine that were not good enough. Every
          screen I kept earned its spot against three I threw out. AI gave me
          execution at the speed of one. Taste did the rest.
        </p>
        <p class="text-xl text-ink leading-relaxed font-display">
          The new workflow does not make designers less important. It makes us
          more important. The work that is left is the hardest work designers do.
        </p>
      </div>
      <!-- Right column: the irreducible two -->
      <div class="md:col-span-5">
        <div class="border-2 border-ink p-6 md:p-8" style="border-radius: 14px; background: #F4EFE5;">
          <p class="font-mono text-[11px] uppercase tracking-[0.18em] text-orange font-semibold mb-6">What does not collapse</p>
          <div class="space-y-8">
            <div>
              <div class="flex items-baseline gap-4 mb-2">
                <span class="font-mono text-[10px] text-orange font-semibold">01</span>
                <p class="font-display text-3xl text-ink leading-tight">Taste.</p>
              </div>
              <p class="text-sm text-ink-soft leading-relaxed pl-8">
                Knowing which one of the ninety-nine ships, and refusing the rest.
              </p>
            </div>
            <div>
              <div class="flex items-baseline gap-4 mb-2">
                <span class="font-mono text-[10px] text-orange font-semibold">02</span>
                <p class="font-display text-3xl text-ink leading-tight">Judgment.</p>
              </div>
              <p class="text-sm text-ink-soft leading-relaxed pl-8">
                The hundred small calls about what this product is, who it is for,
                and what it refuses to be.
              </p>
            </div>
          </div>
          <div class="mt-8 pt-6 border-t border-ink/15">
            <p class="font-display text-base text-ink leading-snug">
              Everything else can compress. These two cannot be delegated, automated, or rushed.
            </p>
          </div>
        </div>
      </div>
    </div>

    <!-- TRANSITION: pivot from thesis to product -->
    <div class="mt-20 md:mt-24 pt-12 md:pt-16 border-t border-ink/10">
      <p class="font-display text-ink leading-tight max-w-[40ch]" style="font-size: clamp(1.75rem, 3vw, 2.5rem);">
        That's the thesis. Course Code is the proof<span class="text-orange">.</span>
      </p>
      <p class="mt-4 text-base text-ink-soft leading-relaxed max-w-reading">
        What follows is the product itself. The problem it solves, the insight that
        shaped it, the bet it ran on, what shipped, and what the numbers say.
      </p>
    </div>
    </div>
  </section>

  <!-- =============================== -->
  <!-- THREE PILLARS with explicit grid alignment + UNIQUE linocut icons -->
  <!-- =============================== -->
  <section class="max-w-7xl mx-auto px-6 md:px-10 py-24 md:py-32">
    <div class="pillar-grid">
      <!-- Problem -->
      <div class="pillar">
        <div class="pillar-icon">
          <svg viewBox="0 0 80 80" xmlns="http://www.w3.org/2000/svg">
            <circle cx="40" cy="40" r="32" fill="none" stroke="#E13D0F" stroke-width="3.5" stroke-linecap="round"/>
            <circle cx="40" cy="40" r="28" fill="none" stroke="#E13D0F" stroke-width="1.5" stroke-dasharray="2 4"/>
            <line x1="40" y1="10" x2="40" y2="16" stroke="#E13D0F" stroke-width="3"/>
            <line x1="40" y1="64" x2="40" y2="70" stroke="#E13D0F" stroke-width="3"/>
            <line x1="10" y1="40" x2="16" y2="40" stroke="#E13D0F" stroke-width="3"/>
            <line x1="64" y1="40" x2="70" y2="40" stroke="#E13D0F" stroke-width="3"/>
            <path d="M40 18 L46 40 L40 38 L34 40 Z" fill="#E13D0F"/>
            <path d="M40 62 L34 40 L40 42 L46 40 Z" fill="#E13D0F" opacity="0.4"/>
            <circle cx="40" cy="40" r="3" fill="#02101D"/>
          </svg>
        </div>
        <div class="pillar-meta">
          <p class="eyebrow mb-3">The problem</p>
          <h2 class="font-display text-3xl text-ink leading-tight">
            Nobody was solving this.
          </h2>
        </div>
        <div class="pillar-body">
          <p class="text-ink-soft leading-relaxed">
            Women face a quiet, universal golf problem. Showing up at a new course
            without knowing the dress code. The rules are real, enforced, and the
            difference between welcome and turned away at the bag drop. But they're
            buried in PDFs, missing from websites, and never written from a woman's
            perspective.
          </p>
        </div>
        <div class="pillar-tagline"></div>
      </div>
      <!-- Insight -->
      <div class="pillar">
        <div class="pillar-icon">
          <svg viewBox="0 0 80 80" xmlns="http://www.w3.org/2000/svg">
