              <line x1="22" y1="22" x2="58" y2="22" stroke="#F4EFE5" stroke-width="1.2" opacity="0.6"/>
              <line x1="26" y1="28" x2="54" y2="28" stroke="#F4EFE5" stroke-width="1.2" opacity="0.6"/>
              <line x1="30" y1="34" x2="50" y2="34" stroke="#F4EFE5" stroke-width="1.2" opacity="0.6"/>
