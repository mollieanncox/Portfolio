        <div class="pillar-icon">
          <svg viewBox="0 0 80 80" xmlns="http://www.w3.org/2000/svg">
            <path d="M40 12 L 60 36 L 50 36 L 50 64 L 30 64 L 30 36 L 20 36 Z" fill="#E13D0F" stroke="#02101D" stroke-width="3" stroke-linejoin="round"/>
