---
import Base from '../layouts/Base.astro';

// Top 4: outcomes-led case studies, shown as cinematic horizontal scroll cards
const showcaseStudies = [
  {
    slug: 'course-code',
    eyebrow: 'Course Code · 2026 to present',
    title: 'An AI-native consumer product',
    hook: 'Built solo with an AI co-founder. A deliberate experiment in what AI collapses and what taste protects.',
    metric: '5.2K',
    metricLabel: 'Active users (30 days)',
    artwork: 'course-code',
  },
  {
    slug: 'linear-migration',
    eyebrow: 'Branch · 2026',
    title: 'Migrating an engineering org from Jira to Linear',
    hook: 'Six-week pilot with real engineers. The data made the case for an enterprise rollout decision.',
    metric: '2.7×',
    metricLabel: 'Throughput per engineer',
    artwork: 'linear',
  },
  {
    slug: 'branch-repositioning',
    eyebrow: 'Branch · 2025 to 2026',
    title: 'Repositioning a company through web and product narrative',
    hook: 'Public B2B SaaS rebrand. An enterprise customer re-signed for three years on the strength of the new positioning and modernized product surface.',
    metric: '$1M',
    metricLabel: 'ARR retained at launch',
    artwork: 'branch-repositioning',
  },
  {
    slug: 'auxin-design-system',
    eyebrow: 'Branch · 2024 to 2026',
    title: 'A design system for a multi-product platform',
    hook: 'Component library, governance, intake, and Figma-to-code alignment across a complex enterprise SaaS surface.',
    metric: '94%',
    metricLabel: 'Component adoption',
    artwork: 'auxin',
  },
];

// Bottom 3: in-flight operating model work, shown as a simple list
const operatingWork = [
  {
    slug: 'inner-circle',
    eyebrow: 'Branch · 2025 to 2026',
    title: 'Building a customer signal engine',
    summary: 'A structured customer program that turned ad hoc feedback into a repeatable VOC loop. EMEA pilot reached 7 enterprise accounts across 4 verticals and influenced 8 roadmap items.',
    metric: '8',
    metricLabel: 'Roadmap items influenced',
  },
  {
    slug: 'px-org-strategy',
    eyebrow: 'Branch · 2025 to 2026',
    title: 'From design function to product experience organization',
    summary: 'Evolved a design-centered team into a multi-disciplinary product organization spanning design, content, documentation, research, education, community, and AI.',
    metric: '6',
    metricLabel: 'Pillars, one North Star',
  },
  {
    slug: 'pdlc-redesign',
    eyebrow: 'Branch · 2025 to 2026',
    title: 'Redesigning the product development lifecycle',
    summary: 'A four-phase operating model with named DACI ownership that pulled design upstream into discovery and closed the loop on measurement.',
    metric: '4',
    metricLabel: 'Phases, full lifecycle',
  },
];

const beliefs = [
  {
    title: 'Personal preference is a hypothesis',
    body: 'Design decisions live or die on evidence. Personal taste is a starting hypothesis, never a conclusion.',
  },
  {
    title: 'Test early, test often',
    body: 'The feedback loop is the work. Get users in front of decisions before they harden. Iterate. Test again.',
  },
  {
    title: 'Roadmap is a capital allocation document',
    body: 'Every line on a roadmap is a bet on what matters most. Make those bets explicit, defensible, and measurable.',
  },
  {
    title: 'Live in the now, build for the future',
    body: 'Solve for the situation in front of you, but build with scalability in mind. Relevant today, extendable tomorrow.',
  },
];
---
<Base title="Mollie Cox · Product & Design Leader · AI-Native Founder">
  <!-- ===================== -->
  <!-- HERO with grid backdrop -->
  <!-- ===================== -->
  <section class="hero-grid relative overflow-hidden">
    <div class="max-w-7xl mx-auto px-6 md:px-10 pt-24 md:pt-20 pb-24 md:pb-32 relative z-10">
      <!-- Currently building indicator (discreet, no job-seeking language) -->
      <div class="inline-flex items-center gap-3 mb-8 px-4 py-2 border border-ink/15 rounded-full bg-cream/70 backdrop-blur-sm">
        <span class="relative flex h-2 w-2">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-orange opacity-75"></span>
          <span class="relative inline-flex rounded-full h-2 w-2 bg-orange"></span>
        </span>
        <span class="font-mono text-xs uppercase tracking-[0.15em] text-ink-soft">
          Currently building Course Code
        </span>
      </div>
      <p class="eyebrow mb-8">Product & Design Leader · AI-Native Founder</p>
      <h1 class="font-display text-display-xl text-ink leading-[0.95] tracking-tight max-w-[18ch]">
        Great design is a moral imperative<span class="brand-period">.</span>
      </h1>
      <p class="mt-8 font-display text-2xl md:text-3xl text-ink-soft max-w-[40ch] leading-snug">
        Product and design leader building executive-grade product experience organizations. AI-native founder shipping live consumer products with an AI co-founder.
      </p>
      <div class="mt-12 max-w-reading">
        <p class="text-xl md:text-2xl text-ink-soft leading-relaxed">
          Twenty years building, scaling, and leading product and design organizations. I architect
          operating models that move design upstream into product strategy. I build
          design systems that scale across complex platforms. And I've redesigned how I
          work around what AI can actually do, shipping a live consumer product solo in
          ten weeks.
        </p>
      </div>
      <div class="mt-16 flex flex-wrap gap-x-12 gap-y-8">
        <div>
          <p class="stat">20</p>
          <p class="stat-label">Years in product & design leadership</p>
        </div>
        <div>
          <p class="stat">2.7×</p>
          <p class="stat-label">Throughput gain (Linear)</p>
        </div>
        <div>
          <p class="stat">5.2K</p>
          <p class="stat-label">Users (Course Code, 30 days)</p>
        </div>
        <div>
          <p class="stat">17K+</p>
          <p class="stat-label">LinkedIn followers</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===================== -->
  <!-- COURSE CODE FOUNDER MOMENT · moved up + upgraded (Move 1 Option B + Move 4 Option A) -->
  <!-- ===================== -->
  <section class="bg-ink text-cream relative overflow-hidden">
    <div class="max-w-7xl mx-auto px-6 md:px-10 py-24 md:py-36 relative z-10">
      <div class="grid md:grid-cols-12 gap-10 md:gap-16 items-center">
        <!-- Left: the founder framing -->
        <div class="md:col-span-7">
          <div class="inline-flex items-center gap-3 mb-8 px-3 py-1.5 border border-orange/40 rounded-full bg-orange/10">
            <span class="relative flex h-2 w-2">
              <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-orange opacity-75"></span>
              <span class="relative inline-flex rounded-full h-2 w-2 bg-orange"></span>
            </span>
            <span class="font-mono text-[10px] uppercase tracking-[0.18em] text-orange font-semibold">Currently building · Live in market</span>
          </div>
          <p class="font-display text-orange leading-none mb-8" style="font-size: clamp(3.5rem, 8vw, 6rem);">
            Course Code<span class="brand-period">.</span>
          </p>
          <h2 class="font-display text-cream leading-[1.05] tracking-tight max-w-[24ch] mb-10" style="font-size: clamp(1.75rem, 3.5vw, 2.75rem);">
            A live consumer product, built solo with an AI co-founder<span class="text-orange">.</span>
          </h2>
          <p class="text-xl text-cream/80 leading-relaxed max-w-[48ch] mb-10">
            18K+ golf courses indexed. 5.2K active users in 30 days. 100% organic growth.
            A deliberate experiment in what AI collapses and what taste protects.
          </p>
          <div class="flex flex-wrap gap-4">
            <a
              href="/work/course-code"
              class="inline-flex items-center gap-2 px-6 py-3 bg-orange text-cream font-mono text-xs uppercase tracking-[0.15em] hover:bg-orange-deep transition-colors"
              style="border-radius: 999px;"
            >
              Read case study →
            </a>
            <a
              href="https://coursecode.golf"
              target="_blank"
              rel="noopener"
              class="inline-flex items-center gap-2 px-6 py-3 border border-cream/30 text-cream font-mono text-xs uppercase tracking-[0.15em] hover:border-orange hover:text-orange transition-colors"
              style="border-radius: 999px;"
            >
              See it live →
            </a>
            <a
              href="/ai"
              class="inline-flex items-center gap-2 px-6 py-3 border border-cream/30 text-cream font-mono text-xs uppercase tracking-[0.15em] hover:border-orange hover:text-orange transition-colors"
              style="border-radius: 999px;"
            >
              Read the AI operating model →
            </a>
          </div>
        </div>
        <!-- Right: the fox + stat strip -->
        <div class="md:col-span-5 flex flex-col items-center md:items-end gap-10">
          <!-- The orange fox, matching the case study hero -->
          <div class="w-full max-w-xs md:max-w-sm">
            <svg viewBox="0 0 277 301" xmlns="http://www.w3.org/2000/svg" class="w-full h-auto" aria-label="Course Code fox mark">
              <path d="M157.433 0.0194147C160.064 0.28246 161.676 2.94593 163.024 5.90516C174.636 31.2571 178.058 58.7139 177.992 87.0253C214.307 112.772 199.242 143.253 239.011 154.663L268.419 163.081C274.142 164.725 277.234 169.887 276.148 175.74C272.267 196.554 258.681 212.173 239.504 220.887C220.326 229.6 189.406 232.1 183.452 250.02C181.84 254.887 181.018 259.819 180.788 264.817L180.67 267.096C180.578 273.283 181.289 279.521 182.33 285.721C179.573 283.247 175.416 281.701 170.458 280.891C170.317 279.63 170.194 278.361 170.097 277.082C169.866 274.155 169.769 271.163 169.867 268.105L169.995 265.711C170.379 258.307 171.814 250.388 174.867 241.602C168.255 238.873 147.532 257.714 150.689 246.042C150.854 245.45 151.61 244.957 152.63 244.036C174.636 224.011 204.8 224.503 229.603 213.883C209.866 214.869 192.005 217.072 173.814 211.581C171.479 210.858 171.446 207.998 172.301 207.142C177.794 201.651 202.761 214.903 240.228 202.572C247.07 200.303 252.925 196.719 257.136 191.458C252.202 188.729 249.274 185.473 246.248 180.969L233.32 186.657C205.36 198.988 150.623 172.616 96.9395 203.525C79.1437 213.784 66.4796 229.141 59.21 248.541C71.2821 243.806 79.9003 236.539 93.2881 234.829L80.0322 253.802C79.177 255.051 76.8417 256.728 78.3877 258.011C80.9219 260.147 109.275 245.187 120.064 247.685C113.222 257.517 107.4 268.961 102.663 281.028C100.208 287.265 98.0441 293.674 96.1797 300.12C94.2075 297.729 89.4431 292.472 79.5605 282.119C70.127 272.236 57.3445 262.334 46.5098 254.907C41.0905 251.193 36.1506 248.092 32.3516 245.918C30.453 244.831 28.8327 243.973 27.5771 243.385C26.95 243.091 26.4061 242.861 25.96 242.703C25.5303 242.551 25.1376 242.447 24.8359 242.447C22.9579 242.447 21.5809 243.475 20.1895 244.663C18.7753 245.87 17.299 247.285 15.1299 248.37H15.1289C14.7446 248.562 13.3407 249.316 11.1123 250.156C10.9008 250.236 9.71064 250.723 7.72363 251.541C8.84172 248.237 9.90812 244.805 10.9395 241.224C11.9443 237.736 12.9182 234.108 13.8818 230.324C7.69769 231.048 5.65784 235.125