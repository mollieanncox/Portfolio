---
import Base from '../layouts/Base.astro';

const caseStudies = [
  {
    slug: 'course-code',
    eyebrow: 'Founder · 2026',
    title: 'Course Code: an AI-native consumer product, solo',
    summary:
      'Built a live, revenue-generating consumer app from zero to paying subscribers in ten weeks. Solo, with an AI co-founder. 4.6K active users, 4,659 courses, real product, real conversion.',
    metric: '4.6K',
    metricLabel: 'Active users in 28 days',
  },
  {
    slug: 'linear-migration',
    eyebrow: 'Branch · 2026',
    title: 'Migrating an engineering org from Jira to Linear',
    summary:
      'A six-week pilot, 2.7× throughput, and a measurable enterprise-scale rollout decision. Built on real engineer data, not vendor demos.',
    metric: '2.7×',
    metricLabel: 'Throughput per engineer',
  },
  {
    slug: 'pdlc-redesign',
    eyebrow: 'Branch · 2025–2026',
    title: 'Redesigning the product development lifecycle',
    summary:
      'A four-phase operating model (Discover, Plan, Build, Measure) with named DACI ownership that pulled design upstream into discovery and closed the loop on measurement.',
    metric: '4 phases',
    metricLabel: 'Cross-functional alignment',
  },
  {
    slug: 'auxin-design-system',
    eyebrow: 'Branch · 2024–2026',
    title: 'Auxin: a design system for a multi-product platform',
    summary:
      'Building a scalable component library, governance model, and Figma-to-code alignment across a complex enterprise SaaS surface.',
    metric: 'System',
    metricLabel: 'Multi-product platform',
  },
  {
    slug: 'fleetio-team-scaling',
    eyebrow: 'Fleetio · 2023',
    title: 'Scaling a design org from 6 to 15',
    summary:
      'Hiring rubrics, leveling frameworks, and onboarding that supported 150% headcount growth without quality degradation.',
    metric: '6 → 15',
    metricLabel: 'Designers',
  },
  {
    slug: 'ivy-positioning',
    eyebrow: 'Branch · 2025',
    title: 'Ivy: positioning AI as category creation',
    summary:
      'A competitive teardown of Adjust, AppsFlyer, and Singular that exposed fragmented AI naming. A positioning play that named the category.',
    metric: 'Category',
    metricLabel: 'Brand positioning',
  },
];

const beliefs = [
  {
    title: "Start with the user",
    body: "Every functionality begins from a real user need. Does this solve a real problem? Does this make their work easier? Is it better than the alternative they have today?",
  },
  {
    title: "Systems match the real world",
    body: "Products speak the user's language, not the system's. Words, patterns, and concepts come from how people already think. Real-world conventions over internal jargon.",
  },
  {
    title: "Personal preference is a hypothesis",
    body: "Design decisions live or die on evidence. Personal taste is a starting hypothesis, never a conclusion. Research and conventions inform; testing decides.",
  },
  {
    title: "Test early, test often",
    body: "The feedback loop is the work. Get users in front of decisions before they harden. Use what you learn to iterate. Then test again.",
  },
  {
    title: "Work should be clean",
    body: "Design shouldn't contain anything irrelevant. Less to read, fewer paths to consider, more focus on what matters. Both informationally and aesthetically.",
  },
  {
    title: "Live in the now, build for the future",
    body: "Solve for the situation in front of you, but build with scalability in mind. Functionality should be relevant today and extendable tomorrow.",
  },
];
---

<Base title="Mollie Cox · Product Design Leader, AI-Native Founder, Speaker">
  <!-- Hero with architectural grid background -->
  <section class="hero-grid relative overflow-hidden">
    <div class="hero-grid-middle-band"></div>
    <div class="max-w-7xl mx-auto px-6 md:px-10 pt-12 md:pt-20 pb-24 md:pb-32 relative z-10">
      <!-- Availability indicator -->
      <div class="inline-flex items-center gap-3 mb-8 px-4 py-2 border border-ink/15 rounded-full bg-cream/70 backdrop-blur-sm">
        <span class="relative flex h-2 w-2">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-orange opacity-75"></span>
          <span class="relative inline-flex rounded-full h-2 w-2 bg-orange"></span>
        </span>
        <span class="font-mono text-xs uppercase tracking-[0.15em] text-ink-soft">
          Open to VP & Head of Design + AI-native operator roles
        </span>
      </div>

      <p class="eyebrow mb-8">Product Design Leader · AI-Native Founder · Speaker</p>

      <h1
        class="font-display text-display-xl text-ink leading-[0.95] tracking-tight max-w-[18ch]"
      >
        Great design is a moral imperative<span class="brand-period">.</span>
      </h1>

      <p class="mt-8 font-display text-2xl md:text-3xl text-ink-soft max-w-[40ch] leading-snug">
        Design and Product Experience leader building executive-grade design organizations. AI-native founder shipping live consumer products with an AI co-founder.
      </p>

      <div class="mt-12 max-w-reading">
        <p class="text-xl md:text-2xl text-ink-soft leading-relaxed">
          Twenty years building, scaling, and leading design organizations. I architect
          operating models that move design upstream into product strategy. I build
          design systems that scale across complex platforms. And I've redesigned how I
          work around what AI can actually do, shipping a live consumer product solo in
          ten weeks.
        </p>
      </div>

      <div class="mt-16 flex flex-wrap gap-x-12 gap-y-8">
        <div>
          <p class="stat">20</p>
          <p class="stat-label">Years leading design</p>
        </div>
        <div>
          <p class="stat">2.7×</p>
          <p class="stat-label">Throughput gain (Linear)</p>
        </div>
        <div>
          <p class="stat">4.6K</p>
          <p class="stat-label">Users (Course Code, 28 days)</p>
        </div>
        <div>
          <p class="stat">17K+</p>
          <p class="stat-label">LinkedIn community</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Currently building -->
  <section class="bg-navy-deep text-cream border-y border-ink/10">
    <div class="max-w-7xl mx-auto px-6 md:px-10 py-16 md:py-20">
      <div class="grid md:grid-cols-12 gap-8 items-end">
        <div class="md:col-span-3">
          <p class="font-mono text-xs uppercase tracking-[0.18em] text-cream/60 mb-3">Currently building</p>
          <p class="font-display text-3xl text-orange">Course Code<span class="text-cream">.</span></p>
        </div>
        <div class="md:col-span-6 max-w-reading">
          <p class="font-display text-2xl text-cream leading-tight mb-4">
            A live, revenue-generating consumer app built solo with an AI co-founder<span class="text-orange">.</span>
          </p>
          <p class="text-cream/80 leading-relaxed">
            4,659 golf courses. 4.6K active users in 28 days. Live Pro tier at $39 a year.
            Phase 1 shipped on time. Ten weeks from concept to revenue.
          </p>
        </div>
        <div class="md:col-span-3 flex flex-col gap-3">
          <a
            href="/work/course-code"
            class="inline-flex items-center justify-center gap-2 px-5 py-3 bg-orange text-cream font-mono text-xs uppercase tracking-[0.15em] hover:bg-orange-deep transition-colors"
          >
            Read case study →
          </a>
          <a
            href="https://coursecode.golf"
            target="_blank"
            rel="noopener"
            class="inline-flex items-center justify-center gap-2 px-5 py-3 border border-cream/30 text-cream font-mono text-xs uppercase tracking-[0.15em] hover:border-orange hover:text-orange transition-colors"
          >
            See it live →
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Recognition row -->
  <section class="border-b border-ink/10 bg-cream-warm/40">
    <div class="max-w-7xl mx-auto px-6 md:px-10 py-12">
      <p class="eyebrow mb-8 text-center md:text-left">Selected recognition</p>
      <div class="grid grid-cols-2 md:grid-cols-5 gap-8 md:gap-12 items-center">
        <div class="text-center md:text-left">
          <p class="font-display text-xl text-ink leading-tight">Course Code</p>
          <p class="font-mono text-xs text-ink-muted mt-1 uppercase tracking-wider">Founder · Live 2026</p>
        </div>
        <div class="text-center md:text-left">
          <p class="font-display text-xl text-ink leading-tight">Bounce Podcast</p>
          <p class="font-mono text-xs text-ink-muted mt-1 uppercase tracking-wider">Host</p>
        </div>
        <div class="text-center md:text-left">
          <p class="font-display text-xl text-ink leading-tight">NMotion</p>
          <p class="font-mono text-xs text-ink-muted mt-1 uppercase tracking-wider">Accelerator · 2025</p>
        </div>
        <div class="text-center md:text-left">
          <p class="font-display text-xl text-ink leading-tight">UNL</p>
          <p class="font-mono text-xs text-ink-muted mt-1 uppercase tracking-wider">Adjunct · 2013–present</p>
        </div>
        <div class="text-center md:text-left">
          <p class="font-display text-xl text-ink leading-tight">Maven</p>
          <p class="font-mono text-xs text-ink-muted mt-1 uppercase tracking-wider">Course Instructor</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Work -->
  <section id="work" class="max-w-7xl mx-auto px-6 md:px-10 py-16">
    <div class="flex items-baseline justify-between mb-16">
      <p class="eyebrow">Selected work</p>
      <p class="text-sm text-ink-muted">2023 to present</p>
    </div>

    <div class="space-y-2">
      {
        caseStudies.map((cs, i) => (
          <a
            href={`/work/${cs.slug}`}
            class="group block py-10 md:py-12 border-t border-ink/10 hover:border-orange transition-colors duration-300"
          >
            <div class="grid md:grid-cols-12 gap-6 items-start">
              <div class="md:col-span-1">
                <p class="font-mono text-xs text-ink-muted">
                  {String(i + 1).padStart(2, '0')}
                </p>
              </div>
              <div class="md:col-span-7">
                <p class="eyebrow mb-3">{cs.eyebrow}</p>
                <h2 class="font-display text-display-md text-ink group-hover:text-orange transition-colors">
                  {cs.title}<span class="text-orange">.</span>
                </h2>
                <p class="mt-4 text-lg text-ink-soft max-w-reading">{cs.summary}</p>
              </div>
              <div class="md:col-span-3 md:text-right">
                <p class="font-display text-3xl md:text-4xl text-ink">{cs.metric}</p>
                <p class="stat-label md:text-right">{cs.metricLabel}</p>
              </div>
              <div class="md:col-span-1 md:text-right pt-2">
                <span
                  class="inline-block text-ink-muted group-hover:text-orange group-hover:translate-x-1 transition-all"
                >
                  →
                </span>
              </div>
            </div>
          </a>
        ))
      }
    </div>
  </section>

  <!-- AI operating model block -->
  <section class="bg-ink text-cream py-24 md:py-32 my-16">
    <div class="max-w-7xl mx-auto px-6 md:px-10">
      <div class="grid md:grid-cols-12 gap-8">
        <div class="md:col-span-3">
          <p class="font-mono text-xs uppercase tracking-[0.18em] text-cream/60 mb-2">How I work</p>
          <p class="font-display text-3xl text-orange">AI Operating Model<span class="text-cream">.</span></p>
        </div>
        <div class="md:col-span-9">
          <h2 class="font-display text-display-md text-cream leading-tight mb-8 max-w-[24ch]">
            How I actually lead with AI<span class="text-orange">.</span>
          </h2>
          <p class="text-lg text-cream/80 leading-relaxed mb-10 max-w-reading">
            Everyone in 2026 says they use AI. Very few have redesigned how they work
            around what AI can actually do. This is not a page about which tools I use.
            It's an operating model: AI as co-founder, not calculator. Authority
            structure, not tool list. The infrastructure that made Course Code possible.
          </p>
          <div class="flex flex-wrap gap-4">
            <a
              href="/ai"
              class="inline-flex items-center gap-2 px-6 py-3 bg-orange text-cream font-mono text-xs uppercase tracking-[0.15em] hover:bg-orange-deep transition-colors"
            >
              Read the operating model →
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Bounce Podcast block -->
  <section class="max-w-7xl mx-auto px-6 md:px-10 py-24 md:py-32 border-t border-ink/10">
    <div class="grid md:grid-cols-12 gap-8">
      <div class="md:col-span-3">
        <p class="eyebrow mb-3">Podcast</p>
        <p class="font-display text-3xl text-orange">Bounce<span class="text-ink">.</span></p>
      </div>
      <div class="md:col-span-9">
        <h2 class="font-display text-display-md text-ink leading-tight mb-8 max-w-[24ch]">
          Conversations on design, leadership, and what actually works<span class="brand-period">.</span>
        </h2>
        <p class="text-lg text-ink-soft leading-relaxed mb-10 max-w-reading">
          Bounce is my podcast on design leadership. Real conversations with practitioners
          about the work, the careers, the choices, and the realities of building
          creative organizations that ship.
        </p>
        <div class="flex flex-wrap gap-4">
          <a
            href="https://open.spotify.com/show/6uE0yn2odzLyV3qyo7jVAP"
            target="_blank"
            rel="noopener"
            class="inline-flex items-center gap-2 px-6 py-3 bg-ink text-cream font-mono text-xs uppercase tracking-[0.15em] hover:bg-orange transition-colors"
          >
            Listen on Spotify →
          </a>
          <a
            href="https://www.youtube.com/@BouncePodcast"
            target="_blank"
            rel="noopener"
            class="inline-flex items-center gap-2 px-6 py-3 border border-ink/30 text-ink font-mono text-xs uppercase tracking-[0.15em] hover:border-orange hover:text-orange transition-colors"
          >
            Watch on YouTube →
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Things I Believe -->
  <section class="max-w-7xl mx-auto px-6 md:px-10 py-24 md:py-32 border-t border-ink/10">
    <div class="grid md:grid-cols-12 gap-8 mb-16">
      <div class="md:col-span-4">
        <p class="eyebrow mb-3">Things I believe</p>
      </div>
      <div class="md:col-span-8">
        <h2 class="font-display text-display-md text-ink leading-tight max-w-[22ch]">
          A short list of convictions about how good work gets made<span class="brand-period">.</span>
        </h2>
      </div>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-4 md:gap-6">
      {
        beliefs.map((belief, i) => (
          <div class="belief-card p-7 md:p-8">
            <div class="flex items-baseline gap-3 mb-4">
              <span class="font-mono text-xs text-orange">{String(i + 1).padStart(2, '0')}</span>
              <h3 class="font-display text-xl text-ink">{belief.title}<span class="text-orange">.</span></h3>
            </div>
            <p class="text-ink-soft leading-relaxed">{belief.body}</p>
          </div>
        ))
      }
    </div>
  </section>

  <!-- About preview -->
  <section class="max-w-7xl mx-auto px-6 md:px-10 py-32 border-t border-ink/10">
    <div class="grid md:grid-cols-12 gap-8">
      <div class="md:col-span-3">
        <p class="eyebrow">About</p>
      </div>
      <div class="md:col-span-9 max-w-reading">
        <p class="font-display text-display-md text-ink leading-tight mb-8">
          I lead by building the operating system, not just the output<span class="brand-period">.</span>
        </p>
        <p class="text-lg text-ink-soft leading-relaxed mb-6">
          Currently Sr. Director of Product Experience at Branch, where I lead product
          design, UX research, content, technical documentation, and design systems for
          an enterprise mobile measurement and engagement platform. I'm also the founder of
          <a href="https://coursecode.golf" target="_blank" rel="noopener" class="text-ink hover:text-orange border-b border-ink/30 hover:border-orange transition-colors">Course Code</a>,
          a live AI-native consumer product I built solo with an AI co-founder.
        </p>
        <p class="text-lg text-ink-soft leading-relaxed mb-10">
          Before Branch I scaled the design organization at Fleetio from 6 to 15
          designers, led platform modernization at DMSi, and held design and creative
          leadership roles at Hudl, GRIN, ORCA.TRADE, Thought District, and HobbyTown.
          I host the <em>Bounce</em> podcast, teach <a href="/teaching" class="text-ink hover:text-orange border-b border-ink/30 hover:border-orange transition-colors">Design Career Catalyst on Maven</a>,
          and have taught UX/UI and design systems as adjunct faculty at the University
          of Nebraska, Lincoln since 2013.
        </p>
        <a
          href="/about"
          class="inline-flex items-center gap-2 font-mono text-sm uppercase tracking-[0.15em] text-ink hover:text-orange transition-colors"
        >
          More about me
          <span>→</span>
        </a>
      </div>
    </div>
  </section>
</Base>
