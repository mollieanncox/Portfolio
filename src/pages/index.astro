 158.847 115.008C155.327 107.116 147.861 105.274 140.295 104.387ZM154.966 100.572C159.143 105.307 162.926 109.582 169.209 113.002C167.926 106.787 162.531 101.427 154.966 100.572ZM156.873 21.3602C148.748 38.8533 145.097 56.5109 143.519 75.5165C152.3 77.6865 159.175 80.8749 168.187 80.9413C166.411 60.2707 164.731 40.52 156.873 21.3602Z" fill="#E13D0F"/>
            </svg>
          </div>
          <!-- Compact stat strip -->
          <div class="grid grid-cols-3 gap-6 md:gap-8 w-full max-w-sm pt-8 border-t border-cream/15">
            <div>
              <p class="font-display text-cream leading-none" style="font-size: clamp(1.5rem, 2.5vw, 2rem);">18K+</p>
              <p class="font-mono text-[10px] uppercase tracking-[0.15em] text-cream/60 mt-2 leading-tight">Courses indexed</p>
            </div>
            <div>
              <p class="font-display text-orange leading-none" style="font-size: clamp(1.5rem, 2.5vw, 2rem);">5.2K</p>
              <p class="font-mono text-[10px] uppercase tracking-[0.15em] text-cream/60 mt-2 leading-tight">Users · 30 days</p>
            </div>
            <div>
              <p class="font-display text-cream leading-none" style="font-size: clamp(1.5rem, 2.5vw, 2rem);">+96%</p>
              <p class="font-mono text-[10px] uppercase tracking-[0.15em] text-cream/60 mt-2 leading-tight">MoM growth</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===================== -->
  <!-- Recognition row -->
  <!-- ===================== -->
  <section class="border-b border-ink/10 bg-cream-warm/40">
    <div class="max-w-7xl mx-auto px-6 md:px-10 py-20">
      <p class="eyebrow mb-8 text-center md:text-left">Selected recognition</p>
      <div class="grid grid-cols-2 md:grid-cols-5 gap-8 md:gap-12 items-start">
        <div class="text-center md:text-left">
          <p class="font-display text-xl text-orange leading-tight">Course Code</p>
          <p class="font-mono text-xs text-ink-muted mt-1 uppercase tracking-wider" style="min-height: 2.4em;">Founder · 2026 to present</p>
        </div>
        <div class="text-center md:text-left">
          <p class="font-display text-xl text-ink leading-tight">Bounce Podcast</p>
          <p class="font-mono text-xs text-ink-muted mt-1 uppercase tracking-wider" style="min-height: 2.4em;">Co-host · 2024 to present</p>
        </div>
        <div class="text-center md:text-left">
          <p class="font-display text-xl text-ink leading-tight">Speaking</p>
          <p class="font-mono text-xs text-ink-muted mt-1 uppercase tracking-wider" style="min-height: 2.4em;">Convey UX · LWT Summit · NebraskaCode</p>
        </div>
        <div class="text-center md:text-left">
          <p class="font-display text-xl text-ink leading-tight">UNL</p>
          <p class="font-mono text-xs text-ink-muted mt-1 uppercase tracking-wider" style="min-height: 2.4em;">Adjunct · 2013 to present</p>
        </div>
        <div class="text-center md:text-left">
          <p class="font-display text-xl text-ink leading-tight">Maven</p>
          <p class="font-mono text-xs text-ink-muted mt-1 uppercase tracking-wider" style="min-height: 2.4em;">Instructor · Since 2025</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===================== -->
  <!-- SELECTED WORK · HORIZONTAL SCROLL SHOWCASE (top 4 outcomes-led case studies) -->
  <!-- ===================== -->
  <section id="work" class="bg-cream-warm/40 border-y border-ink/10 py-20 md:py-28 overflow-hidden">
    <div class="max-w-7xl mx-auto px-6 md:px-10 mb-12 md:mb-16">
      <div class="flex flex-wrap items-baseline justify-between gap-y-4">
        <div>
          <p class="eyebrow mb-3">Selected work</p>
          <h2 class="font-display text-display-md text-ink leading-tight max-w-[26ch]">
            Four case studies. Four measurable outcomes<span class="brand-period">.</span>
          </h2>
        </div>
        <p class="font-mono text-xs uppercase tracking-[0.15em] text-ink-muted">
          Drag · scroll · or use the arrows
        </p>
      </div>
    </div>
    <!-- Horizontal scroll container -->
    <div class="relative">
      <!-- Left arrow -->
      <button
        type="button"
        id="showcase-prev"
        class="hidden md:flex absolute left-4 lg:left-6 top-1/2 -translate-y-1/2 z-20 w-12 h-12 items-center justify-center bg-ink text-cream hover:bg-orange transition-colors shadow-xl"
        style="border-radius: 999px;"
        aria-label="Previous case study"
      >
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
          <path d="M13 4L7 10L13 16" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
      <!-- Right arrow -->
      <button
        type="button"
        id="showcase-next"
        class="hidden md:flex absolute right-4 lg:right-6 top-1/2 -translate-y-1/2 z-20 w-12 h-12 items-center justify-center bg-ink text-cream hover:bg-orange transition-colors shadow-xl"
        style="border-radius: 999px;"
        aria-label="Next case study"
      >
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
          <path d="M7 4L13 10L7 16" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
      <!-- Scroll track -->
      <div
        id="showcase-track"
        class="flex gap-6 md:gap-8 overflow-x-auto scroll-smooth px-6 md:px-16 lg:px-20 pb-6"
        style="scroll-snap-type: x mandatory; scrollbar-width: none; -ms-overflow-style: none;"
      >
        {
          showcaseStudies.map((cs, i) => (
            <a
              href={`/work/${cs.slug}`}
              class="group showcase-card flex-shrink-0 w-[85vw] sm:w-[70vw] md:w-[600px] lg:w-[640px] bg-ink text-cream overflow-hidden transition-transform hover:-translate-y-1"
              style="scroll-snap-align: start; border-radius: 18px;"
            >
              <!-- Artwork area: ~60% of card height -->
              <div class="relative bg-ink/95 px-8 md:px-12 pt-10 md:pt-12 pb-6 flex items-center justify-center" style="min-height: 320px;">
                {cs.artwork === 'course-code' && (
