---
import Base from '../layouts/Base.astro';

const caseStudies = [
  {
    slug: 'course-code',
    eyebrow: 'Course Code · 2026 to present',
    title: 'Course Code: an AI-native consumer product, solo',
    summary:
      'Built a live, revenue-generating consumer app from zero to paying subscribers in ten weeks. Solo, with an AI co-founder.',
    metric: '4.6K',
    metricLabel: 'Active users (28 days)',
  },
  {
    slug: 'branch-repositioning',
    eyebrow: 'Branch · 2025 to 2026',
    title: 'Repositioning a company through web and product narrative',
    summary:
      'Led the product and experience strategy behind a public B2B SaaS rebrand. A new market story, a product-led website, a sharper voice. Launched at sales kickoff, live in market.',
    metric: '150+',
    metricLabel: 'Pages, three-tier triage',
  },
  {
    slug: 'px-org-strategy',
    eyebrow: 'Branch · 2025 to 2026',
    title: 'From design function to product experience organization',
    summary:
      'Evolved a design-centered team into a multi-disciplinary product organization spanning design, content, documentation, research, education, community, and AI. Six pillars, one North Star.',
    metric: '6',
    metricLabel: 'Pillars, one North Star',
  },
  {
    slug: 'pdlc-redesign',
    eyebrow: 'Branch · 2025 to 2026',
    title: 'Redesigning the product development lifecycle',
    summary:
      'A four-phase operating model with named DACI ownership that pulled design upstream into discovery and closed the loop on measurement.',
    metric: '4',
    metricLabel: 'Phases, full lifecycle',
  },
  {
    slug: 'auxin-design-system',
    eyebrow: 'Branch · 2024 to 2026',
    title: 'A design system for a multi-product platform',
    summary:
      'Scalable component library, governance model, intake process, and Figma-to-code alignment across a complex enterprise SaaS surface.',
    metric: '9',
    metricLabel: 'Operational artifacts',
  },
  {
    slug: 'linear-migration',
    eyebrow: 'Branch · 2026',
    title: 'Migrating an engineering org from Jira to Linear',
    summary:
      'A six-week pilot, 2.7× throughput, and a measurable enterprise-scale rollout decision. Built on real engineer data.',
    metric: '2.7×',
    metricLabel: 'Throughput per engineer',
  },
  {
    slug: 'inner-circle',
    eyebrow: 'Branch · 2025 to 2026',
    title: 'Building a customer signal engine',
    summary:
      'A structured customer program that turned ad hoc feedback into a repeatable VOC loop. EMEA pilot, North America rollout, formalized as part of PX strategy.',
    metric: '4',
    metricLabel: 'Regions, 2026 target',
  },
];

const beliefs = [
  {
    title: 'Personal preference is a hypothesis',
    body: 'Design decisions live or die on evidence. Personal taste is a starting hypothesis, never a conclusion.',
  },
  {
    title: 'Test early, test often',
    body: 'The feedback loop is the work. Get users in front of decisions before they harden. Iterate. Test again.',
  },
  {
    title: 'Roadmap is a capital allocation document',
    body: 'Every line on a roadmap is a bet on what matters most. Make those bets explicit, defensible, and measurable.',
  },
  {
    title: 'Live in the now, build for the future',
    body: 'Solve for the situation in front of you, but build with scalability in mind. Relevant today, extendable tomorrow.',
  },
];
---

<Base title="Mollie Cox · Product & Design Leader · AI-Native Founder">
  <!-- ===================== -->
  <!-- HERO with grid backdrop -->
  <!-- ===================== -->
  <section class="hero-grid relative overflow-hidden">
    <div class="max-w-7xl mx-auto px-6 md:px-10 pt-24 md:pt-20 pb-24 md:pb-32 relative z-10">
      <!-- Currently building indicator (discreet, no job-seeking language) -->
      <div class="inline-flex items-center gap-3 mb-8 px-4 py-2 border border-ink/15 rounded-full bg-cream/70 backdrop-blur-sm">
        <span class="relative flex h-2 w-2">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-orange opacity-75"></span>
          <span class="relative inline-flex rounded-full h-2 w-2 bg-orange"></span>
        </span>
        <span class="font-mono text-xs uppercase tracking-[0.15em] text-ink-soft">
          Currently building Course Code
        </span>
      </div>

      <p class="eyebrow mb-8">Product & Design Leader · AI-Native Founder</p>

      <h1 class="font-display text-display-xl text-ink leading-[0.95] tracking-tight max-w-[18ch]">
        Great design is a moral imperative<span class="brand-period">.</span>
      </h1>

      <p class="mt-8 font-display text-2xl md:text-3xl text-ink-soft max-w-[40ch] leading-snug">
        Product and design leader building executive-grade product experience organizations. AI-native founder shipping live consumer products with an AI co-founder.
      </p>

      <div class="mt-12 max-w-reading">
        <p class="text-xl md:text-2xl text-ink-soft leading-relaxed">
          Twenty years building, scaling, and leading product and design organizations. I architect
          operating models that move design upstream into product strategy. I build
          design systems that scale across complex platforms. And I've redesigned how I
          work around what AI can actually do, shipping a live consumer product solo in
          ten weeks.
        </p>
      </div>

      <div class="mt-16 flex flex-wrap gap-x-12 gap-y-8">
        <div>
          <p class="stat">20</p>
          <p class="stat-label">Years in product & design leadership</p>
        </div>
        <div>
          <p class="stat">2.7×</p>
          <p class="stat-label">Throughput gain (Linear)</p>
        </div>
        <div>
          <p class="stat">4.6K</p>
          <p class="stat-label">Users (Course Code, 28 days)</p>
        </div>
        <div>
          <p class="stat">17K+</p>
          <p class="stat-label">LinkedIn followers</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===================== -->
  <!-- Currently building -->
  <!-- ===================== -->
  <section class="bg-ink text-cream relative overflow-hidden">
    <div class="max-w-7xl mx-auto px-6 md:px-10 py-20 md:py-28 relative z-10">
      <div class="grid md:grid-cols-12 gap-8 items-start">
        <div class="md:col-span-3">
          <p class="font-mono text-xs uppercase tracking-[0.18em] text-cream/60 mb-3">Currently building</p>
          <p class="font-display text-3xl text-orange">Course Code</p>
        </div>
        <div class="md:col-span-6 max-w-reading">
          <p class="font-display text-2xl text-cream leading-tight mb-4">
            A live, revenue-generating consumer app built solo with an AI co-founder<span class="text-orange">.</span>
          </p>
          <p class="text-cream/80 leading-relaxed">
            4,659 golf courses. 4.6K active users in 28 days. Live Pro tier at $39 a year.
            Phase 1 shipped on time. Ten weeks from concept to revenue.
          </p>
        </div>
        <div class="md:col-span-3 flex flex-col gap-3">
          <a
            href="/work/course-code"
            class="inline-flex items-center justify-center gap-2 px-5 py-3 bg-orange text-cream font-mono text-xs uppercase tracking-[0.15em] hover:bg-orange-deep transition-colors"
            style="border-radius: 999px;"
          >
            Read case study →
          </a>
          <a
            href="https://coursecode.golf"
            target="_blank"
            rel="noopener"
            class="inline-flex items-center justify-center gap-2 px-5 py-3 border border-cream/30 text-cream font-mono text-xs uppercase tracking-[0.15em] hover:border-orange hover:text-orange transition-colors"
            style="border-radius: 999px;"
          >
            See it live →
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ===================== -->
  <!-- Recognition row -->
  <!-- ===================== -->
  <section class="border-b border-ink/10 bg-cream-warm/40">
    <div class="max-w-7xl mx-auto px-6 md:px-10 py-20">
      <p class="eyebrow mb-8 text-center md:text-left">Selected recognition</p>
      <div class="grid grid-cols-2 md:grid-cols-5 gap-8 md:gap-12 items-start">
        <div class="text-center md:text-left">
          <p class="font-display text-xl text-orange leading-tight">Course Code</p>
          <p class="font-mono text-xs text-ink-muted mt-1 uppercase tracking-wider" style="min-height: 2.4em;">Founder · 2026 to present</p>
        </div>
        <div class="text-center md:text-left">
          <p class="font-display text-xl text-ink leading-tight">Bounce Podcast</p>
          <p class="font-mono text-xs text-ink-muted mt-1 uppercase tracking-wider" style="min-height: 2.4em;">Co-host · 2024 to present</p>
        </div>
        <div class="text-center md:text-left">
          <p class="font-display text-xl text-ink leading-tight">Veer</p>
          <p class="font-mono text-xs text-ink-muted mt-1 uppercase tracking-wider" style="min-height: 2.4em;">NMotion 2025</p>
        </div>
        <div class="text-center md:text-left">
          <p class="font-display text-xl text-ink leading-tight">UNL</p>
          <p class="font-mono text-xs text-ink-muted mt-1 uppercase tracking-wider" style="min-height: 2.4em;">Adjunct · 2013 to present</p>
        </div>
        <div class="text-center md:text-left">
          <p class="font-display text-xl text-ink leading-tight">Maven</p>
          <p class="font-mono text-xs text-ink-muted mt-1 uppercase tracking-wider" style="min-height: 2.4em;">Instructor · Since 2025</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===================== -->
  <!-- Work grid -->
  <!-- ===================== -->
  <section id="work" class="max-w-7xl mx-auto px-6 md:px-10 py-16 md:py-24">
    <div class="flex items-baseline justify-between mb-16">
      <p class="eyebrow">Selected work</p>
      <p class="text-sm text-ink-muted">2024 to present</p>
    </div>

    <div class="space-y-2">
      {
        caseStudies.map((cs, i) => (
          <a
            href={`/work/${cs.slug}`}
            class="group block py-10 md:py-12 border-t border-ink/10 hover:border-orange transition-colors duration-300"
          >
            <div class="grid md:grid-cols-12 gap-6 items-start">
              <div class="md:col-span-1">
                <p class="font-mono text-xs text-ink-muted">
                  {String(i + 1).padStart(2, '0')}
                </p>
              </div>
              <div class="md:col-span-7">
                <p class="eyebrow mb-3">{cs.eyebrow}</p>
                <h2 class="font-display text-display-md text-ink group-hover:text-orange transition-colors leading-tight">
                  {cs.title}
                </h2>
                <p class="mt-4 text-lg text-ink-soft max-w-reading">{cs.summary}</p>
              </div>
              <div class="md:col-span-3 md:text-right">
                <p class="font-display text-3xl md:text-4xl text-ink">{cs.metric}</p>
                <p class="stat-label md:text-right">{cs.metricLabel}</p>
              </div>
              <div class="md:col-span-1 md:text-right pt-2">
                <span
                  class="inline-block text-ink-muted group-hover:text-orange group-hover:translate-x-1 transition-all"
                >
                  →
                </span>
              </div>
            </div>
          </a>
        ))
      }
    </div>
  </section>

  <!-- ===================== -->
  <!-- AI Operating Model block -->
  <!-- ===================== -->
  <section class="bg-ink text-cream py-24 md:py-32">
    <div class="max-w-7xl mx-auto px-6 md:px-10">
      <div class="grid md:grid-cols-12 gap-8">
        <div class="md:col-span-3">
          <p class="font-mono text-xs uppercase tracking-[0.18em] text-cream/60 mb-2">How I work</p>
          <p class="font-display text-3xl text-orange">AI Operating Model</p>
        </div>
        <div class="md:col-span-9">
          <h2 class="font-display text-display-md text-cream leading-tight mb-8 max-w-[24ch]">
            How I actually lead with AI<span class="text-orange">.</span>
          </h2>
          <p class="text-lg text-cream/80 leading-relaxed mb-10 max-w-reading">
            Everyone in 2026 says they use AI. Very few have redesigned how they work
            around what AI can actually do. This is not a page about which tools I use.
            It's an operating model: AI as co-founder, not calculator. Authority
            structure, not tool list. The infrastructure that made Course Code possible.
          </p>
          <a
            href="/ai"
            class="inline-flex items-center gap-2 px-6 py-3 bg-orange text-cream font-mono text-xs uppercase tracking-[0.15em] hover:bg-orange-deep transition-colors"
            style="border-radius: 999px;"
          >
            Read the operating model →
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ===================== -->
  <!-- Bounce block - rich episode embeds, co-hosted -->
  <!-- ===================== -->
  <section class="max-w-7xl mx-auto px-6 md:px-10 py-24 md:py-32 border-b border-ink/10">
    <!-- Section header -->
    <div class="grid md:grid-cols-12 gap-8 mb-12 md:mb-16">
      <div class="md:col-span-5">
        <p class="eyebrow mb-6">Podcast</p>
        <p class="font-display text-5xl md:text-6xl text-orange mb-6 leading-none">Bounce<span class="brand-period">.</span></p>
        <p class="font-mono text-xs uppercase tracking-[0.15em] text-ink-muted">
          Co-hosted with Claire Flowers
        </p>
      </div>
      <div class="md:col-span-7">
        <h2 class="font-display text-display-md text-ink leading-tight mb-6 max-w-[24ch]">
          Product team fails, flops, and the lessons that carry forward.
        </h2>
        <p class="text-lg text-ink-soft leading-relaxed max-w-reading">
          Real conversations with practitioners about the work, the careers, the choices, and
          the realities of building things that ship. Not the success-only version.
        </p>
      </div>
    </div>

    <!-- Episode embeds: 3 columns of real episode players -->
    <div class="grid md:grid-cols-3 gap-6 md:gap-8 mb-10">
      <!-- Episode 1 -->
      <iframe
        style="border-radius:12px"
        src="https://open.spotify.com/embed/episode/38SgLFucJ0AXv2PCGiBWVR?utm_source=generator&theme=0"
        width="100%"
        height="232"
        frameBorder="0"
        allowfullscreen=""
        allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture"
        loading="lazy"
        title="Bounce Podcast"
      ></iframe>

      <!-- Episode 2 -->
      <iframe
        style="border-radius:12px"
        src="https://open.spotify.com/embed/episode/7KegJOqD6572O2pQsBlMfC?utm_source=generator&theme=0"
        width="100%"
        height="232"
        frameBorder="0"
        allowfullscreen=""
        allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture"
        loading="lazy"
        title="Bounce Podcast"
      ></iframe>

      <!-- Episode 3 -->
      <iframe
        style="border-radius:12px"
        src="https://open.spotify.com/embed/episode/6VMhAiNHQ6uC1dY5oCaBc0?utm_source=generator&theme=0"
        width="100%"
        height="232"
        frameBorder="0"
        allowfullscreen=""
        allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture"
        loading="lazy"
        title="Bounce Podcast"
      ></iframe>
    </div>

    <!-- Listen on row: integrated, no divider above -->
    <div class="flex flex-wrap items-baseline gap-x-6 gap-y-2">
      <p class="font-mono text-xs uppercase tracking-[0.15em] text-ink-muted">Listen on</p>
      <a
        href="https://open.spotify.com/show/6uE0yn2odzLyV3qyo7jVAP"
        target="_blank"
        rel="noopener"
        class="font-mono text-xs uppercase tracking-[0.15em] text-ink hover:text-orange transition-colors border-b border-ink/30 hover:border-orange pb-0.5"
      >
        Spotify →
      </a>
      <a
        href="https://podcasts.apple.com/us/podcast/bounce/id1745556826"
        target="_blank"
        rel="noopener"
        class="font-mono text-xs uppercase tracking-[0.15em] text-ink hover:text-orange transition-colors border-b border-ink/30 hover:border-orange pb-0.5"
      >
        Apple Podcasts →
      </a>
      <a
        href="https://www.youtube.com/@BouncePodcast"
        target="_blank"
        rel="noopener"
        class="font-mono text-xs uppercase tracking-[0.15em] text-ink hover:text-orange transition-colors border-b border-ink/30 hover:border-orange pb-0.5"
      >
        YouTube →
      </a>
    </div>
  </section>

  <!-- ===================== -->
  <!-- Things I Believe (now with linocut icons per principle) -->
  <!-- ===================== -->
  <section class="max-w-7xl mx-auto px-6 md:px-10 py-24 md:py-32">
    <div class="grid md:grid-cols-12 gap-8 mb-16">
      <div class="md:col-span-4">
        <p class="eyebrow mb-3">Things I believe</p>
      </div>
      <div class="md:col-span-8">
        <h2 class="font-display text-display-md text-ink leading-tight max-w-[22ch]">
          A short list of convictions about how good work gets made.
        </h2>
      </div>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-4 md:gap-6">
      <!-- 01 Personal preference is a hypothesis -->
      <div class="belief-card p-7 md:p-8">
        <div class="linocut-icon">
          <svg viewBox="0 0 80 80" xmlns="http://www.w3.org/2000/svg">
            <!-- Flask -->
            <path d="M32 10 L 32 32 L 18 62 C 16 66, 19 70, 24 70 L 56 70 C 61 70, 64 66, 62 62 L 48 32 L 48 10" fill="#E13D0F" stroke="#02101D" stroke-width="3" stroke-linejoin="round"/>
            <line x1="28" y1="10" x2="52" y2="10" stroke="#02101D" stroke-width="3" stroke-linecap="round"/>
            <!-- Liquid level -->
            <path d="M24 50 L 56 50" stroke="#02101D" stroke-width="2"/>
            <!-- Bubbles -->
            <circle cx="34" cy="58" r="2" fill="#F4EFE5"/>
            <circle cx="44" cy="62" r="1.5" fill="#F4EFE5"/>
            <circle cx="38" cy="64" r="1" fill="#F4EFE5"/>
          </svg>
        </div>
        <div class="flex items-baseline gap-3 mb-3">
          <span class="font-mono text-xs text-orange">01</span>
          <h3 class="font-display text-xl text-ink leading-tight">{beliefs[0].title}.</h3>
        </div>
        <p class="text-ink-soft leading-relaxed">{beliefs[0].body}</p>
      </div>

      <!-- 02 Test early, test often -->
      <div class="belief-card p-7 md:p-8">
        <div class="linocut-icon">
          <svg viewBox="0 0 80 80" xmlns="http://www.w3.org/2000/svg">
            <!-- Circular arrow loop -->
            <path d="M40 18 a22 22 0 1 1 -22 22" fill="none" stroke="#E13D0F" stroke-width="6" stroke-linecap="round"/>
            <path d="M40 18 L 30 12 L 30 24 Z" fill="#E13D0F"/>
            <circle cx="40" cy="40" r="6" fill="#02101D"/>
          </svg>
        </div>
        <div class="flex items-baseline gap-3 mb-3">
          <span class="font-mono text-xs text-orange">02</span>
          <h3 class="font-display text-xl text-ink leading-tight">{beliefs[1].title}.</h3>
        </div>
        <p class="text-ink-soft leading-relaxed">{beliefs[1].body}</p>
      </div>

      <!-- 03 Roadmap is a capital allocation document -->
      <div class="belief-card p-7 md:p-8">
        <div class="linocut-icon">
          <svg viewBox="0 0 80 80" xmlns="http://www.w3.org/2000/svg">
            <!-- Bar chart bars of unequal heights = allocation -->
            <rect x="14" y="44" width="12" height="28" fill="#E13D0F" stroke="#02101D" stroke-width="2.5" stroke-linejoin="round"/>
            <rect x="30" y="28" width="12" height="44" fill="#E13D0F" stroke="#02101D" stroke-width="2.5" stroke-linejoin="round"/>
            <rect x="46" y="36" width="12" height="36" fill="#E13D0F" stroke="#02101D" stroke-width="2.5" stroke-linejoin="round"/>
            <rect x="62" y="52" width="10" height="20" fill="#E13D0F" stroke="#02101D" stroke-width="2.5" stroke-linejoin="round"/>
            <!-- Hatching on the tallest bar to give it weight -->
            <line x1="32" y1="36" x2="40" y2="36" stroke="#02101D" stroke-width="1" opacity="0.5"/>
            <line x1="32" y1="44" x2="40" y2="44" stroke="#02101D" stroke-width="1" opacity="0.5"/>
            <line x1="32" y1="52" x2="40" y2="52" stroke="#02101D" stroke-width="1" opacity="0.5"/>
            <line x1="32" y1="60" x2="40" y2="60" stroke="#02101D" stroke-width="1" opacity="0.5"/>
            <!-- Baseline -->
            <line x1="8" y1="72" x2="74" y2="72" stroke="#02101D" stroke-width="2.5" stroke-linecap="round"/>
          </svg>
        </div>
        <div class="flex items-baseline gap-3 mb-3">
          <span class="font-mono text-xs text-orange">03</span>
          <h3 class="font-display text-xl text-ink leading-tight">{beliefs[2].title}.</h3>
        </div>
        <p class="text-ink-soft leading-relaxed">{beliefs[2].body}</p>
      </div>

      <!-- 04 Live in the now, build for the future -->
      <div class="belief-card p-7 md:p-8">
        <div class="linocut-icon">
          <svg viewBox="0 0 80 80" xmlns="http://www.w3.org/2000/svg">
            <!-- Bridge -->
            <path d="M10 50 Q 40 26, 70 50" fill="none" stroke="#E13D0F" stroke-width="6" stroke-linecap="round"/>
            <line x1="10" y1="50" x2="10" y2="70" stroke="#02101D" stroke-width="3" stroke-linecap="round"/>
            <line x1="70" y1="50" x2="70" y2="70" stroke="#02101D" stroke-width="3" stroke-linecap="round"/>
            <line x1="22" y1="44" x2="22" y2="70" stroke="#02101D" stroke-width="2"/>
            <line x1="34" y1="36" x2="34" y2="70" stroke="#02101D" stroke-width="2"/>
            <line x1="46" y1="36" x2="46" y2="70" stroke="#02101D" stroke-width="2"/>
            <line x1="58" y1="44" x2="58" y2="70" stroke="#02101D" stroke-width="2"/>
            <line x1="6" y1="70" x2="74" y2="70" stroke="#02101D" stroke-width="3" stroke-linecap="round"/>
          </svg>
        </div>
        <div class="flex items-baseline gap-3 mb-3">
          <span class="font-mono text-xs text-orange">04</span>
          <h3 class="font-display text-xl text-ink leading-tight">{beliefs[3].title}.</h3>
        </div>
        <p class="text-ink-soft leading-relaxed">{beliefs[3].body}</p>
      </div>
    </div>
  </section>

  <!-- ===================== -->
  <!-- About preview -->
  <!-- ===================== -->
  <section class="max-w-7xl mx-auto px-6 md:px-10 py-24 md:py-32 border-t border-ink/10">
    <div class="grid md:grid-cols-12 gap-8">
      <div class="md:col-span-3">
        <p class="eyebrow">About</p>
      </div>
      <div class="md:col-span-9 max-w-reading">
        <p class="font-display text-display-md text-ink leading-tight mb-8">
          I lead by building the operating system, not just the output<span class="brand-period">.</span>
        </p>
        <p class="text-lg text-ink-soft leading-relaxed mb-6">
          Currently Sr. Director of Product Experience at Branch, where I lead product
          strategy, design, UX research, content, technical documentation, and design systems for
          an enterprise mobile measurement and engagement platform. I'm also the founder of
          <a href="https://coursecode.golf" target="_blank" rel="noopener" class="text-ink hover:text-orange border-b border-ink/30 hover:border-orange transition-colors">Course Code</a>,
          a live AI-native consumer product I built solo with an AI co-founder.
        </p>
        <p class="text-lg text-ink-soft leading-relaxed mb-10">
          Before Branch I scaled the design organization at Fleetio from 6 to 15
          designers, led platform modernization at DMSi, and held design leadership
