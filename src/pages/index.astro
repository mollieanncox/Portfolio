  <!-- ===================== -->
  <!-- Horizontal scroll script + scrollbar hide -->
  <!-- ===================== -->
  <style is:global>
    #showcase-track::-webkit-scrollbar { display: none; }
    .showcase-card {
      transition: transform 0.3s ease;
    }
    /* Cursor changes when dragging */
    #showcase-track {
      cursor: grab;
    }
    #showcase-track.dragging {
      cursor: grabbing;
      scroll-behavior: auto;
    }
    #showcase-track.dragging a {
      pointer-events: none;
    }
  </style>
  <script is:inline>
    (function() {
      const track = document.getElementById('showcase-track');
      const prevBtn = document.getElementById('showcase-prev');
      const nextBtn = document.getElementById('showcase-next');
      if (!track) return;

      // Arrow button scrolling: scroll by one card width
      function getCardWidth() {
        const firstCard = track.querySelector('.showcase-card');
        if (!firstCard) return 600;
        const gap = parseInt(window.getComputedStyle(track).columnGap || '32', 10);
        return firstCard.offsetWidth + gap;
      }
      if (prevBtn) {
        prevBtn.addEventListener('click', function() {
          track.scrollBy({ left: -getCardWidth(), behavior: 'smooth' });
        });
      }
      if (nextBtn) {
        nextBtn.addEventListener('click', function() {
          track.scrollBy({ left: getCardWidth(), behavior: 'smooth' });
        });
      }

      // Drag-to-scroll (mouse)
      let isDown = false;
      let startX = 0;
      let scrollLeft = 0;
      let hasDragged = false;

      track.addEventListener('mousedown', function(e) {
        // Only initiate drag with primary button
        if (e.button !== 0) return;
        isDown = true;
        hasDragged = false;
        startX = e.pageX - track.offsetLeft;
        scrollLeft = track.scrollLeft;
      });
      track.addEventListener('mouseleave', function() {
        if (isDown) {
          isDown = false;
          track.classList.remove('dragging');
        }
      });
      track.addEventListener('mouseup', function() {
        isDown = false;
        // Defer removing dragging class so the click handler on the link can be intercepted
        setTimeout(function() {
          track.classList.remove('dragging');
        }, 0);
      });
      track.addEventListener('mousemove', function(e) {
        if (!isDown) return;
        const x = e.pageX - track.offsetLeft;
        const walk = (x - startX) * 1.5;
        if (Math.abs(walk) > 5 && !hasDragged) {
          hasDragged = true;
          track.classList.add('dragging');
        }
        if (hasDragged) {
          e.preventDefault();
          track.scrollLeft = scrollLeft - walk;
        }
      });

      // Prevent click after drag
      track.querySelectorAll('a').forEach(function(link) {
        link.addEventListener('click', function(e) {
          if (track.classList.contains('dragging')) {
            e.preventDefault();
          }
        });
      });

      // Keyboard arrow navigation when section is focused
      document.addEventListener('keydown', function(e) {
        const rect = track.getBoundingClientRect();
        const inView = rect.top < window.innerHeight && rect.bottom > 0;
        if (!inView) return;
        if (e.key === 'ArrowLeft') {
          track.scrollBy({ left: -getCardWidth(), behavior: 'smooth' });
        } else if (e.key === 'ArrowRight') {
          track.scrollBy({ left: getCardWidth(), behavior: 'smooth' });
        }
      });
    })();
  </script>
