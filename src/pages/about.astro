---
import Base from '../layouts/Base.astro';

const leadershipTestimonials = [
  {
    quote: "Mollie has a rare combination of charisma, exceptional intelligence, and leadership in one human being, and the field of design is lucky to have someone in it with such a skillset. Her leadership inspires confidence and fosters a sense of purpose.",
    name: "Zeljka Hassler",
    role: "Sr. Product Design Manager",
  },
  {
    quote: "One of the standout qualities of Mollie is her commitment to mentorship. She invests time in developing her team's skills, encouraging them to push boundaries and explore new ideas. Her feedback is always constructive and insightful.",
    name: "Dani Weidner",
    role: "Senior Product Designer",
  },
];
---

<Base title="About · Mollie Cox">
  <section class="max-w-7xl mx-auto px-6 md:px-10 pt-12 md:pt-20 pb-16">
    <p class="eyebrow mb-8">About</p>

    <h1
      class="font-display text-display-lg text-ink leading-[1.0] tracking-tight max-w-[20ch]"
    >
      I lead by building the operating system, not just the output<span class="brand-period">.</span>
    </h1>
  </section>

  <section class="max-w-7xl mx-auto px-6 md:px-10 pb-32">
    <div class="grid md:grid-cols-12 gap-8 md:gap-16">
      <!-- Left column: portrait + quick facts -->
      <div class="md:col-span-4">
        <img
          src="/portrait.png"
          alt="Mollie Cox"
          class="w-full mb-8"
          loading="lazy"
        />

        <div class="space-y-6">
          <div>
            <p class="eyebrow mb-2">Based in</p>
            <p class="text-ink">Lincoln, Nebraska</p>
            <p class="text-sm text-ink-muted">Open to relocation</p>
          </div>
          <div>
            <p class="eyebrow mb-2">Currently</p>
            <p class="text-ink">Sr. Director of Product Experience</p>
            <p class="text-sm text-ink-muted">Branch · branch.io</p>
          </div>
          <div>
            <p class="eyebrow mb-2">Also</p>
            <p class="text-ink">Co-Founder & CEO</p>
            <p class="text-sm text-ink-muted">Veer · NMotion Spring 2025</p>
          </div>
          <div>
            <p class="eyebrow mb-2">Host</p>
            <p class="text-ink">
              <a href="https://open.spotify.com/show/6uE0yn2odzLyV3qyo7jVAP" target="_blank" rel="noopener" class="hover:text-orange transition-colors">
                Bounce Podcast →
              </a>
            </p>
            <p class="text-sm text-ink-muted">Design and leadership conversations</p>
          </div>
          <div>
            <p class="eyebrow mb-2">Teaching</p>
            <p class="text-ink">
              <a href="/teaching" class="hover:text-orange transition-colors">
                Maven course + UNL adjunct →
              </a>
            </p>
            <p class="text-sm text-ink-muted">Adjunct at UNL since 2013</p>
          </div>
        </div>
      </div>

      <!-- Right column: long-form bio -->
      <div class="md:col-span-8">
        <div class="prose-mc">
          <p class="text-xl text-ink-soft leading-relaxed mb-10">
            Twenty years building, scaling, and leading design organizations across
            enterprise SaaS, fintech, and consumer products, plus direct experience as a
            venture-backed CEO. I think about design as a business function, not a craft
            silo.
          </p>

          <h2>How I lead</h2>
          <p>
            I architect operating models that move design upstream into product strategy
            instead of downstream into UI execution. At Branch I redesigned the
            company-wide product development lifecycle into a four-phase model with named
            DACI ownership, paired problem and technical solution briefs, mandatory
            success metrics before Build, and a 90-day Invest, Iterate, or Deprecate
            decision loop that closed the longstanding gap between launch and measurement.
          </p>

          <p>
            I build design systems that scale across complex platforms. Auxin at Branch
            spans a multi-product enterprise SaaS surface, with reusable components, a
            governance model, and Figma-to-code alignment practices that change the
            relationship between design and engineering.
          </p>

          <p>
            And I translate design decisions into executive-ready business cases grounded
            in real data. I don't bring opinions to leadership. I bring tested
            methodologies and the numbers behind them.
          </p>

          <h2>Where I've been</h2>
          <p>
            <strong>Branch.</strong> Sr. Director of Product Experience leading product
            design, UX research, content, technical documentation, design systems, and
            customer insight programs across a mobile measurement and engagement platform
            serving global enterprise customers.
          </p>

          <p>
            <strong>Veer.</strong> Co-Founder and CEO of an AI-powered healthcare
            workforce platform. Selected for the NMotion (powered by gener8tor) Spring
            2025 accelerator with $100K investment from gener8tor and Invest Nebraska. Led
            the company through accelerator participation, market validation, and ultimate
            wind-down decision.
          </p>

          <p>
            <strong>Fleetio.</strong> Director of Product Design. Built and scaled the
            product and content design organization from 6 to 15 designers, establishing
            hiring rubrics, leveling frameworks, and onboarding processes that supported
            150% headcount growth without quality degradation.
          </p>

          <p>
            <strong>GRIN, Hudl, DMSi, Resort Lifestyle Communities, ORCA.TRADE, Thought
              District, HobbyTown.</strong> Design and creative leadership roles across
            influencer marketing SaaS, sports analytics with hardware integration,
            enterprise ERP, senior living, fintech options trading (CMO), digital agency
            ($1.2M+ client budgets), and national retail franchise (helped grow annual
            sales to $300M+).
          </p>

          <h2>Speaking, teaching, and writing</h2>
          <p>
            I host <strong>Bounce</strong>, a podcast on design and leadership, available
            on <a href="https://open.spotify.com/show/6uE0yn2odzLyV3qyo7jVAP" target="_blank" rel="noopener" class="text-ink hover:text-orange border-b border-ink/30 hover:border-orange transition-colors">Spotify</a>
            and <a href="https://www.youtube.com/@BouncePodcast" target="_blank" rel="noopener" class="text-ink hover:text-orange border-b border-ink/30 hover:border-orange transition-colors">YouTube</a>.
            I run <strong>Design Career Catalyst</strong>, a paid cohort course on
            <a href="https://maven.com/mollie-cox/design-career-catalyst" target="_blank" rel="noopener" class="text-ink hover:text-orange border-b border-ink/30 hover:border-orange transition-colors">Maven</a>
            built for senior designers ready to lead. I've taught UX/UI, design systems,
            and atomic design as adjunct faculty at the University of Nebraska, Lincoln since
            2013. And I have a community of 17,000+ followers on LinkedIn where I write
            about design as a business function and what it takes to ship great work.
          </p>

          <h2>Outside of work</h2>
          <p>
            I play golf (13 handicap), and I live in Lincoln with deep roots in the
            Midwest tech and creative community. I'm a graduate of UNL (BA, Theatre
            Performance), CalArts (MFA, Acting), and Kaplan University (MBA, Summa Cum
            Laude).
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Leadership testimonials block -->
  <section class="bg-cream-warm/40 border-y border-ink/10">
    <div class="max-w-7xl mx-auto px-6 md:px-10 py-24 md:py-32">
      <div class="grid md:grid-cols-12 gap-8 mb-16">
        <div class="md:col-span-4">
          <p class="eyebrow mb-3">Voices</p>
        </div>
        <div class="md:col-span-8">
          <h2 class="font-display text-display-md text-ink leading-tight max-w-[24ch]">
            From people I've led<span class="brand-period">.</span>
          </h2>
        </div>
      </div>

      <div class="grid md:grid-cols-2 gap-6 md:gap-8">
        {
          leadershipTestimonials.map((t) => (
            <figure class="bg-cream p-8 md:p-10 border border-ink/10">
              <blockquote class="text-lg text-ink-soft leading-relaxed mb-6">
                "{t.quote}"
              </blockquote>
              <figcaption>
                <p class="font-display text-lg text-ink">{t.name}</p>
                <p class="font-mono text-xs text-ink-muted mt-1 uppercase tracking-wider">{t.role}</p>
              </figcaption>
            </figure>
          ))
        }
      </div>

      <p class="mt-10 text-sm text-ink-muted">
        <a href="/teaching" class="hover:text-orange border-b border-ink-muted/30 hover:border-orange transition-colors">
          Read more testimonials from designers I've led, taught, and mentored →
        </a>
      </p>
    </div>
  </section>

  <!-- Contact -->
  <section class="max-w-7xl mx-auto px-6 md:px-10 py-24">
    <div class="prose-mc max-w-reading">
      <p>
        <a
          href="mailto:molliecox@gmail.com"
          class="text-ink hover:text-orange border-b border-ink/30 hover:border-orange transition-colors"
        >
          molliecox@gmail.com
        </a>
        ·
        <a
          href="https://linkedin.com/in/molliecox"
          target="_blank"
          rel="noopener"
          class="text-ink hover:text-orange border-b border-ink/30 hover:border-orange transition-colors"
        >
          LinkedIn
        </a>
      </p>
    </div>
  </section>
</Base>
