---
import Base from './Base.astro';

interface Props {
  title: string;
  eyebrow: string;
  summary: string;
  role: string;
  duration: string;
  team?: string;
  outcome: string;
}

const { title, eyebrow, summary, role, duration, team, outcome } = Astro.props;
---

<Base title={`${title} · Mollie Cox`}>
  <article>
    <!-- Case study hero -->
    <header class="max-w-7xl mx-auto px-6 md:px-10 pt-12 md:pt-16 pb-16">
      <a
        href="/#work"
        class="inline-flex items-center gap-2 font-mono text-xs uppercase tracking-[0.15em] text-ink-muted hover:text-orange transition-colors mb-12"
      >
        ← All work
      </a>

      <p class="eyebrow mb-8">{eyebrow}</p>

      <h1 class="font-display text-display-lg text-ink leading-[1.0] max-w-[20ch]">
        {title}<span class="brand-period">.</span>
      </h1>

      <p class="mt-10 text-xl text-ink-soft leading-relaxed max-w-reading">
        {summary}
      </p>

      <!-- Meta block -->
      <div class="mt-16 grid grid-cols-2 md:grid-cols-4 gap-6 pt-8 border-t border-ink/10">
        <div>
          <p class="eyebrow mb-2">Role</p>
          <p class="text-ink">{role}</p>
        </div>
        <div>
          <p class="eyebrow mb-2">Duration</p>
          <p class="text-ink">{duration}</p>
        </div>
        {
          team && (
            <div>
              <p class="eyebrow mb-2">Team</p>
              <p class="text-ink">{team}</p>
            </div>
          )
        }
        <div>
          <p class="eyebrow mb-2">Outcome</p>
          <p class="text-ink">{outcome}</p>
        </div>
      </div>
    </header>

    <!-- Case study body -->
    <div class="max-w-7xl mx-auto px-6 md:px-10 py-16">
      <div class="prose-mc">
        <slot />
      </div>
    </div>
  </article>
</Base>
