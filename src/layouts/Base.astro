---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = 'Mollie Cox. Product and design leader. Twenty years building product experience at enterprise SaaS, fintech, and consumer. Sr. Director of Product Experience at Branch. Founder of Course Code, a live AI-native consumer product built solo with an AI co-founder.',
} = Astro.props;

// Strip trailing slash for consistent comparison across Astro build modes
const path = Astro.url.pathname.replace(/\/$/, '') || '/';
const isWork = path === '/' || path.startsWith('/work');
const isAI = path === '/ai';
const isTeaching = path === '/teaching';
const isAbout = path === '/about';
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Adobe Fonts (New Spirit) -->
    <link rel="stylesheet" href="https://use.typekit.net/nbd2daq.css" />

    <!-- Fontshare (Satoshi) -->
    <link
      rel="stylesheet"
      href="https://api.fontshare.com/v2/css?f[]=satoshi@301,401,501,701&display=swap"
    />

    <!-- Google Fonts (JetBrains Mono) -->
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500&display=swap"
    />

    <title>{title}</title>

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content="/portrait.png" />
  </head>
  <body>
    <header class="fixed top-0 left-0 right-0 z-50 backdrop-blur-md bg-cream/80 border-b border-ink/5">
      <nav class="max-w-7xl mx-auto px-6 md:px-10 py-5 flex items-center justify-between">
        <a href="/" class="font-display text-xl text-ink hover:text-orange transition-colors">
          Mollie Cox<span class="brand-period">.</span>
        </a>

        <!-- Desktop nav -->
        <div class="hidden md:flex items-center gap-7 text-sm">
          <a href="/#work" class={`nav-link ${isWork ? 'nav-link-current' : ''}`}>Work</a>
          <a href="/ai" class={`nav-link ${isAI ? 'nav-link-current' : ''}`}>AI</a>
          <a href="/teaching" class={`nav-link ${isTeaching ? 'nav-link-current' : ''}`}>Teaching</a>
          <a href="/about" class={`nav-link ${isAbout ? 'nav-link-current' : ''}`}>About</a>
          <a href="https://open.spotify.com/show/6uE0yn2odzLyV3qyo7jVAP" target="_blank" rel="noopener" class="nav-link">Bounce</a>

          <!-- Contact CTA button -->
          <a
            href="mailto:molliecox@gmail.com"
            class="inline-flex items-center gap-2 px-5 py-2 bg-ink text-cream font-mono text-xs uppercase tracking-[0.15em] hover:bg-orange transition-colors"
            style="border-radius: 999px;"
          >
            Contact →
          </a>
        </div>

        <!-- Mobile hamburger button -->
        <button
          id="mobile-menu-toggle"
          class="md:hidden w-10 h-10 flex flex-col items-center justify-center gap-1.5"
          aria-label="Toggle menu"
        >
          <span class="hamburger-line block w-6 h-0.5 bg-ink transition-all duration-300"></span>
          <span class="hamburger-line block w-6 h-0.5 bg-ink transition-all duration-300"></span>
          <span class="hamburger-line block w-6 h-0.5 bg-ink transition-all duration-300"></span>
        </button>
      </nav>
    </header>

    <!-- Mobile menu overlay - OUTSIDE the header to avoid backdrop-blur stacking context trap -->
    <div
      id="mobile-menu"
      class="md:hidden"
      style="display: none; position: fixed; top: 0; left: 0; right: 0; bottom: 0; background-color: #F4EFE5; z-index: 100;"
    >
      <!-- Close button row, matches nav header dimensions -->
      <div style="display: flex; align-items: center; justify-content: space-between; padding: 1.25rem 1.5rem;">
        <a href="/" class="font-display text-xl text-ink mobile-nav-link" style="text-decoration: none;">
          Mollie Cox<span class="brand-period">.</span>
        </a>
        <button
          id="mobile-menu-close"
          style="width: 2.5rem; height: 2.5rem; display: flex; align-items: center; justify-content: center; background: transparent; border: none; cursor: pointer;"
          aria-label="Close menu"
        >
          <svg width="22" height="22" viewBox="0 0 22 22" fill="none">
            <line x1="2" y1="2" x2="20" y2="20" stroke="#02101D" stroke-width="2" stroke-linecap="round"/>
            <line x1="20" y1="2" x2="2" y2="20" stroke="#02101D" stroke-width="2" stroke-linecap="round"/>
          </svg>
        </button>
      </div>

      <!-- Nav links centered in remaining vertical space -->
      <div style="display: flex; flex-direction: column; justify-content: center; padding: 0 2rem 3rem; height: calc(100vh - 5rem);">
        <div style="display: flex; flex-direction: column; gap: 2rem;">
          <a href="/#work" class="mobile-nav-link font-display text-ink" style="font-size: 2.25rem; text-decoration: none;">Work<span class="brand-period">.</span></a>
          <a href="/ai" class="mobile-nav-link font-display text-ink" style="font-size: 2.25rem; text-decoration: none;">AI<span class="brand-period">.</span></a>
          <a href="/teaching" class="mobile-nav-link font-display text-ink" style="font-size: 2.25rem; text-decoration: none;">Teaching<span class="brand-period">.</span></a>
          <a href="/about" class="mobile-nav-link font-display text-ink" style="font-size: 2.25rem; text-decoration: none;">About<span class="brand-period">.</span></a>
          <a href="https://open.spotify.com/show/6uE0yn2odzLyV3qyo7jVAP" target="_blank" rel="noopener" class="mobile-nav-link font-display text-ink" style="font-size: 2.25rem; text-decoration: none;">Bounce<span class="brand-period">.</span></a>
        </div>

        <div style="margin-top: 4rem;">
          <a
            href="mailto:molliecox@gmail.com"
            class="mobile-nav-link font-mono"
            style="display: inline-flex; align-items: center; gap: 0.5rem; padding: 0.75rem 1.5rem; background-color: #02101D; color: #F4EFE5; font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.15em; border-radius: 999px; text-decoration: none;"
          >
            Contact →
          </a>
        </div>
      </div>
    </div>

    <script>
      const toggle = document.getElementById('mobile-menu-toggle');
      const closeBtn = document.getElementById('mobile-menu-close');
      const menu = document.getElementById('mobile-menu');
      const lines = document.querySelectorAll('.hamburger-line');
      const mobileLinks = document.querySelectorAll('.mobile-nav-link');

      let isOpen = false;

      function setMenu(open) {
        if (!menu) return;
        isOpen = open;
        if (open) {
          menu.style.display = 'block';
          document.body.style.overflow = 'hidden';
          // Hamburger morphs to X
          lines[0]?.classList.add('translate-y-2', 'rotate-45');
          lines[1]?.classList.add('opacity-0');
          lines[2]?.classList.add('-translate-y-2', '-rotate-45');
        } else {
          menu.style.display = 'none';
          document.body.style.overflow = '';
          // X back to hamburger
          lines[0]?.classList.remove('translate-y-2', 'rotate-45');
          lines[1]?.classList.remove('opacity-0');
          lines[2]?.classList.remove('-translate-y-2', '-rotate-45');
        }
      }

      toggle?.addEventListener('click', () => setMenu(!isOpen));
      closeBtn?.addEventListener('click', () => setMenu(false));
      mobileLinks.forEach(link => link.addEventListener('click', () => setMenu(false)));

      // Close on resize to desktop (avoids stuck-open state on rotation)
      window.addEventListener('resize', () => {
        if (window.innerWidth >= 768 && isOpen) setMenu(false);
      });
    </script>

    <main class="pt-24">
      <slot />
    </main>

    <footer class="py-16 border-t border-ink/10">
      <div class="max-w-7xl mx-auto px-6 md:px-10 grid md:grid-cols-3 gap-8">
        <div>
          <p class="font-display text-2xl text-ink mb-2">
            Mollie Cox<span class="text-orange">.</span>
          </p>
          <p class="text-sm text-ink-muted">
            Design and Product Experience leader. AI-native founder<span class="text-orange">.</span>
            <br />Lincoln, Nebraska.
          </p>
        </div>
        <div>
          <p class="eyebrow mb-3">Get in touch</p>
          <a
            href="mailto:molliecox@gmail.com"
            class="block text-ink-soft hover:text-orange transition-colors"
          >
            molliecox@gmail.com
          </a>
          <a
            href="https://linkedin.com/in/molliecox"
            target="_blank"
            rel="noopener"
            class="block text-ink-soft hover:text-orange transition-colors mt-1"
          >
            LinkedIn
          </a>
          <a
            href="https://coursecode.golf"
            target="_blank"
            rel="noopener"
            class="block text-ink-soft hover:text-orange transition-colors mt-1"
          >
            Course Code
          </a>
          <a
            href="https://open.spotify.com/show/6uE0yn2odzLyV3qyo7jVAP"
            target="_blank"
            rel="noopener"
            class="block text-ink-soft hover:text-orange transition-colors mt-1"
          >
            Bounce on Spotify
          </a>
        </div>
        <div class="md:text-right">
          <p class="font-mono text-xs text-ink-muted">© 2026 Mollie Cox</p>
        </div>
      </div>
    </footer>
  </body>
</html>
